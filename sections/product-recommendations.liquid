      "content": "Mobile image style"
    },
    {
      "type": "text",
      "id": "mobile_image_aspect_ratio",
      "label": "Mobile image aspect ratio",
      "default": "0.9 / 1"
    },
    {
      "type": "select",
      "id": "mobile_image_fit",
