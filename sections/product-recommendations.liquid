      "default": "400"
    },
    {
      "type": "text",
      "id": "mobile_heading_letter_spacing",
      "label": "Mobile heading letter spacing",
      "default": "0.42em"
    },
    {
      "type": "text",
      "id": "mobile_product_font_family",
      "label": "Mobile product font family",
