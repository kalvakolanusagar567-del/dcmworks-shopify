      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "mobile_heading_bottom_spacing",
      "label": "Mobile heading bottom spacing",
      "min": 0,
      "max": 40,
      "step": 1,
