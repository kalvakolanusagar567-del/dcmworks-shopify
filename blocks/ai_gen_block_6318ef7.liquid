{% doc %}
  @prompt
    01 Collection product cards with product image swipe inside each card, 3 products, centered heading/subheading, no shop all link, add to cart buttons, desktop grid and mobile horizontal card layout.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  {{ block.settings.heading_font | font_face }}
  {{ block.settings.body_font | font_face }}

  .ai-shop-collection-{{ ai_gen_id }} {
    width: 100%;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.desktop_padding_top }}px {{ block.settings.desktop_padding_x }}px {{ block.settings.desktop_padding_bottom }}px;
    border-top: {{ block.settings.section_top_border_px }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.section_bottom_border_px }}px solid {{ block.settings.border_color }};
    overflow: hidden;
  }

  .ai-shop-collection__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-shop-collection__header-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    margin-bottom: {{ block.settings.header_bottom_gap }}px;
    text-align: center;
  }

  .ai-shop-collection__header-{{ ai_gen_id }} > div {
    width: 100%;
    text-align: center;
  }

  .ai-shop-collection__eyebrow-{{ ai_gen_id }} {
    text-align: center;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: {{ block.settings.eyebrow_weight }};
    letter-spacing: {{ block.settings.eyebrow_spacing_px }}px;
    line-height: 1;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 {{ block.settings.eyebrow_bottom_gap }}px;
  }

  .ai-shop-collection__title-{{ ai_gen_id }} {
    text-align: center;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_spacing_px }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-shop-collection__title-muted-{{ ai_gen_id }} {
    color: {{ block.settings.heading_muted_color }};
    font-weight: {{ block.settings.heading_muted_weight }};
  }

  .ai-shop-collection__shop-link-{{ ai_gen_id }} {
    display: none !important;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.link_size }}px;
    font-weight: {{ block.settings.link_weight }};
    letter-spacing: {{ block.settings.shop_link_spacing_px }}px;
    text-transform: uppercase;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    white-space: nowrap;
  }

  .ai-shop-collection__shop-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-shop-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-shop-collection__card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .ai-shop-collection__card-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.08);
  }

  .ai-shop-collection__image-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: {{ block.settings.image_background }};
  }

  .ai-shop-collection__image-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    text-decoration: none;
    background: {{ block.settings.image_background }};
  }

  .ai-shop-collection__image-track-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-shop-collection__image-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  .ai-shop-collection__image-slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    min-width: 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  .ai-shop-collection__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ block.settings.image_fit }};
    transition: transform 0.35s ease;
  }

  .ai-shop-collection__card-{{ ai_gen_id }}:hover .ai-shop-collection__image-{{ ai_gen_id }} {
    transform: scale(1.035);
  }

  .ai-shop-collection__image-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    z-index: 7;
    transform: translateY(-50%);
    width: {{ block.settings.image_arrow_size }}px;
    height: {{ block.settings.image_arrow_size }}px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.7);
    background: rgba(0,0,0,.45);
    color: #ffffff;
    font-size: {{ block.settings.image_arrow_font_size }}px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  .ai-shop-collection__image-arrow--prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-shop-collection__image-arrow--next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-shop-collection__image-dots-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    bottom: 10px;
    z-index: 7;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
  }

  .ai-shop-collection__image-dot-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,.55);
    padding: 0;
    cursor: pointer;
  }

  .ai-shop-collection__image-dot-{{ ai_gen_id }}.is-active {
    background: #ffffff;
  }

  .ai-shop-collection__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_top }}px;
    left: {{ block.settings.badge_left }}px;
    z-index: 8;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.badge_size }}px;
    font-weight: {{ block.settings.badge_weight }};
    letter-spacing: {{ block.settings.badge_spacing_px }}px;
    text-transform: uppercase;
    line-height: 1;
    padding: 7px 9px;
    border-radius: {{ block.settings.badge_radius }}px;
  }

  .ai-shop-collection__soldout-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_top }}px;
    right: {{ block.settings.badge_left }}px;
    z-index: 8;
    background: #111111;
    color: #ffffff;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.badge_size }}px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1;
    padding: 7px 9px;
    border-radius: {{ block.settings.badge_radius }}px;
  }

  .ai-shop-collection__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .ai-shop-collection__product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: {{ block.settings.product_title_weight }};
    line-height: {{ block.settings.product_title_line_height }};
    letter-spacing: {{ block.settings.product_title_spacing_px }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 {{ block.settings.product_title_bottom_gap }}px;
  }

  .ai-shop-collection__product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-shop-collection__price-row-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: {{ block.settings.price_bottom_gap }}px;
  }

  .ai-shop-collection__price-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.price_color }};
    line-height: 1;
    margin: 0;
  }

  .ai-shop-collection__compare-price-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    line-height: 1;
    margin: 0;
  }

  .ai-shop-collection__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.description_size }}px;
    font-weight: {{ block.settings.description_weight }};
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.description_bottom_gap }}px;
  }

  .ai-shop-collection__button-{{ ai_gen_id }} {
    width: 100%;
    min-height: {{ block.settings.button_height }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_radius }}px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    letter-spacing: {{ block.settings.button_spacing_px }}px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    margin-top: auto;
  }

  .ai-shop-collection__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-shop-collection__button-{{ ai_gen_id }}:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .ai-shop-collection__empty-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    padding: 40px 20px;
    border: 1px dashed {{ block.settings.border_color }};
    text-align: center;
    color: {{ block.settings.description_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  @media screen and (max-width: 989px) {
    .ai-shop-collection__grid-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.card_gap }}px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .ai-shop-collection__grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }

    .ai-shop-collection__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
      min-width: calc((100% - {{ block.settings.card_gap }}px) / 2);
      scroll-snap-align: start;
    }

    .ai-shop-collection__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.tablet_heading_size }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-shop-collection-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px 0 {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-shop-collection__inner-{{ ai_gen_id }} {
      max-width: none;
      width: 100%;
    }

    .ai-shop-collection__header-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_side_padding }}px;
      margin-bottom: {{ block.settings.mobile_header_bottom_gap }}px;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .ai-shop-collection__header-{{ ai_gen_id }} > div {
      width: 100%;
      text-align: center;
    }

    .ai-shop-collection__eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_eyebrow_size }}px;
      letter-spacing: {{ block.settings.mobile_eyebrow_spacing_px }}px;
      margin-bottom: {{ block.settings.mobile_eyebrow_bottom_gap }}px;
    }

    .ai-shop-collection__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      line-height: {{ block.settings.mobile_heading_line_height }};
      letter-spacing: {{ block.settings.mobile_heading_spacing_px }}px;
    }

    .ai-shop-collection__shop-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_link_size }}px;
      letter-spacing: {{ block.settings.mobile_shop_link_spacing_px }}px;
    }

    .ai-shop-collection__grid-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_card_gap }}px;
      padding-left: {{ block.settings.mobile_side_padding }}px;
      padding-right: {{ block.settings.mobile_side_padding }}px;
      scroll-padding-left: {{ block.settings.mobile_side_padding }}px;
    }

    .ai-shop-collection__card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_card_width }}%;
      min-width: {{ block.settings.mobile_card_width }}%;
      border-radius: {{ block.settings.mobile_card_radius }}px;
    }

    .ai-shop-collection__image-link-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.mobile_image_aspect_ratio }};
    }

    .ai-shop-collection__image-arrow-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_image_arrow_size }}px;
      height: {{ block.settings.mobile_image_arrow_size }}px;
      font-size: {{ block.settings.mobile_image_arrow_font_size }}px;
    }

    .ai-shop-collection__content-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_card_padding }}px;
    }

    .ai-shop-collection__product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_card_title_size }}px;
      line-height: {{ block.settings.mobile_product_title_line_height }};
      letter-spacing: {{ block.settings.mobile_product_title_spacing_px }}px;
    }

    .ai-shop-collection__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_price_size }}px;
    }

    .ai-shop-collection__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_size }}px;
      line-height: {{ block.settings.mobile_description_line_height }};
    }

    .ai-shop-collection__button-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_button_height }}px;
      font-size: {{ block.settings.mobile_button_size }}px;
    }
  }
{% endstyle %}

<product-card-image-swipe-{{ ai_gen_id }} class="ai-shop-collection-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-shop-collection__inner-{{ ai_gen_id }}">
    <div class="ai-shop-collection__header-{{ ai_gen_id }}">
      <div>
        {% if block.settings.eyebrow != blank %}
          <p class="ai-shop-collection__eyebrow-{{ ai_gen_id }}">
            {{ block.settings.eyebrow }}
          </p>
        {% endif %}

        <h2 class="ai-shop-collection__title-{{ ai_gen_id }}">
          {{ block.settings.heading }}
          {% if block.settings.heading_muted != blank %}
            <span class="ai-shop-collection__title-muted-{{ ai_gen_id }}">
              {{ block.settings.heading_muted }}
            </span>
          {% endif %}
        </h2>
      </div>

    </div>

    <div class="ai-shop-collection__grid-{{ ai_gen_id }}">
      {% assign has_products = false %}

      {% for i in (1..3) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign badge_key = 'product_' | append: i | append: '_badge'
          assign description_key = 'product_' | append: i | append: '_description'

          assign card_product = block.settings[product_key]
          assign card_badge = block.settings[badge_key]
          assign card_description = block.settings[description_key]
        %}

        {% if card_product != blank %}
          {% assign has_products = true %}
          {% assign current_variant = card_product.selected_or_first_available_variant %}
          {% assign product_images = card_product.media | where: 'media_type', 'image' %}
          {% assign image_count = product_images.size %}

          {% if image_count == 0 and card_product.featured_image %}
            {% assign image_count = 1 %}
          {% endif %}

          <div class="ai-shop-collection__card-{{ ai_gen_id }}">
            <div class="ai-shop-collection__image-slider-{{ ai_gen_id }}" data-product-image-slider>
              <a href="{{ card_product.url }}" class="ai-shop-collection__image-link-{{ ai_gen_id }}">
                {% if card_badge != blank %}
                  <span class="ai-shop-collection__badge-{{ ai_gen_id }}">
                    {{ card_badge }}
                  </span>
                {% endif %}

                {% unless current_variant.available %}
                  <span class="ai-shop-collection__soldout-{{ ai_gen_id }}">
                    Sold out
                  </span>
                {% endunless %}

                <div class="ai-shop-collection__image-track-{{ ai_gen_id }}" data-product-image-track>
                  {% if product_images.size > 0 %}
                    {% for media in product_images %}
                      <div class="ai-shop-collection__image-slide-{{ ai_gen_id }}" data-product-image-slide>
                        <img
                          src="{{ media.preview_image | image_url: width: 1000 }}"
                          alt="{{ media.alt | escape }}"
                          class="ai-shop-collection__image-{{ ai_gen_id }}"
                          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                          width="{{ media.preview_image.width }}"
                          height="{{ media.preview_image.height }}"
                        >
                      </div>
                    {% endfor %}
                  {% elsif card_product.featured_image %}
                    <div class="ai-shop-collection__image-slide-{{ ai_gen_id }}" data-product-image-slide>
                      <img
                        src="{{ card_product.featured_image | image_url: width: 1000 }}"
                        alt="{{ card_product.featured_image.alt | escape }}"
                        class="ai-shop-collection__image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="{{ card_product.featured_image.width }}"
                        height="{{ card_product.featured_image.height }}"
                      >
                    </div>
                  {% else %}
                    <div class="ai-shop-collection__image-slide-{{ ai_gen_id }}" data-product-image-slide>
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
              </a>

              {% if image_count > 1 %}
                <button
                  class="ai-shop-collection__image-arrow-{{ ai_gen_id }} ai-shop-collection__image-arrow--prev-{{ ai_gen_id }}"
                  type="button"
                  data-product-image-prev
                  aria-label="Previous image"
                >
                  ‹
                </button>

                <button
                  class="ai-shop-collection__image-arrow-{{ ai_gen_id }} ai-shop-collection__image-arrow--next-{{ ai_gen_id }}"
                  type="button"
                  data-product-image-next
                  aria-label="Next image"
                >
                  ›
                </button>

                <div class="ai-shop-collection__image-dots-{{ ai_gen_id }}">
                  {% for n in (1..image_count) %}
                    <button
                      class="ai-shop-collection__image-dot-{{ ai_gen_id }} {% if forloop.first %}is-active{% endif %}"
                      type="button"
                      data-product-image-dot
                      data-index="{{ forloop.index0 }}"
                      aria-label="Go to image {{ forloop.index }}"
                    ></button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="ai-shop-collection__content-{{ ai_gen_id }}">
              <h3 class="ai-shop-collection__product-title-{{ ai_gen_id }}">
                <a href="{{ card_product.url }}">
                  {{ card_product.title }}
                </a>
              </h3>

              <div class="ai-shop-collection__price-row-{{ ai_gen_id }}">
                <p class="ai-shop-collection__price-{{ ai_gen_id }}">
                  {{ current_variant.price | money }}
                </p>

                {% if current_variant.compare_at_price > current_variant.price %}
                  <p class="ai-shop-collection__compare-price-{{ ai_gen_id }}">
                    {{ current_variant.compare_at_price | money }}
                  </p>
                {% endif %}
              </div>

              {% if card_description != blank %}
                <p class="ai-shop-collection__description-{{ ai_gen_id }}">
                  {{ card_description }}
                </p>
              {% elsif card_product.description != blank and block.settings.show_product_description %}
                <p class="ai-shop-collection__description-{{ ai_gen_id }}">
                  {{ card_product.description | strip_html | truncate: 95 }}
                </p>
              {% endif %}

              {% form 'product', card_product %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">

                <button
                  type="submit"
                  name="add"
                  class="ai-shop-collection__button-{{ ai_gen_id }}"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  {% if current_variant.available %}
                    {{ block.settings.button_text }}
                  {% else %}
                    Sold out
                  {% endif %}
                </button>
              {% endform %}
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% unless has_products %}
        <div class="ai-shop-collection__empty-{{ ai_gen_id }}">
          Select 3 products for this section.
        </div>
      {% endunless %}
    </div>
  </div>
</product-card-image-swipe-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCardImageSwipe{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        const sliders = this.querySelectorAll('[data-product-image-slider]');

        sliders.forEach((slider) => {
          const track = slider.querySelector('[data-product-image-track]');
          const slides = Array.from(slider.querySelectorAll('[data-product-image-slide]'));
          const prev = slider.querySelector('[data-product-image-prev]');
          const next = slider.querySelector('[data-product-image-next]');
          const dots = Array.from(slider.querySelectorAll('[data-product-image-dot]'));

          if (!track || !slides.length) return;

          const getIndex = () => {
            const width = slides[0].offsetWidth || track.clientWidth;
            if (!width) return 0;
            return Math.round(track.scrollLeft / width);
          };

          const update = () => {
            const index = Math.max(0, Math.min(slides.length - 1, getIndex()));

            dots.forEach((dot, dotIndex) => {
              dot.classList.toggle('is-active', dotIndex === index);
            });
          };

          const goTo = (index) => {
            const safeIndex = Math.max(0, Math.min(slides.length - 1, index));
            const width = slides[0].offsetWidth || track.clientWidth;

            track.scrollTo({
              left: width * safeIndex,
              behavior: 'smooth'
            });
          };

          if (prev) {
            prev.addEventListener('click', (event) => {
              event.preventDefault();
              event.stopPropagation();
              goTo(getIndex() - 1);
            });
          }

          if (next) {
            next.addEventListener('click', (event) => {
              event.preventDefault();
              event.stopPropagation();
              goTo(getIndex() + 1);
            });
          }

          dots.forEach((dot) => {
            dot.addEventListener('click', (event) => {
              event.preventDefault();
              event.stopPropagation();
              goTo(parseInt(dot.dataset.index || '0', 10));
            });
          });

          track.addEventListener('scroll', () => {
            window.requestAnimationFrame(update);
          });

          window.addEventListener('resize', update);
          update();
        });
      }
    }

    if (!customElements.get('product-card-image-swipe-{{ ai_gen_id }}')) {
      customElements.define('product-card-image-swipe-{{ ai_gen_id }}', ProductCardImageSwipe{{ ai_gen_id }});
    }
  })();
</script>

