{% doc %}
  @prompt
    Product showcase with product media gallery, video first, thumbnails, variants, add to cart, dynamic checkout, and responsive mobile layout.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign selected_product = block.settings.product | default: product %}

{% style %}
  {{ block.settings.heading_font | font_face }}
  {{ block.settings.body_font | font_face }}

  .dp-showcase-{{ ai_gen_id }} {
    width: 100%;
    background: {{ block.settings.section_bg }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.desktop_padding_top }}px {{ block.settings.desktop_padding_x }}px {{ block.settings.desktop_padding_bottom }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  .dp-showcase__wrap-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: {{ block.settings.media_width }}% 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .dp-showcase__main-media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.desktop_media_aspect }};
    overflow: hidden;
    border-radius: {{ block.settings.media_radius }}px;
    background: #111;
  }

  .dp-showcase__track-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .dp-showcase__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .dp-showcase__slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
    background: #111;
  }

  .dp-showcase__image-{{ ai_gen_id }},
  .dp-showcase__video-{{ ai_gen_id }},
  .dp-showcase__external-video-{{ ai_gen_id }},
  .dp-showcase__slide-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border: 0;
  }

  .dp-showcase__play-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 4;
    width: {{ block.settings.play_size }}px;
    height: {{ block.settings.play_size }}px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 3px solid #fff;
    background: rgba(0,0,0,.35);
    pointer-events: none;
  }


  .dp-showcase__play-{{ ai_gen_id }} {
    display: none;
  }

  .dp-showcase__play-{{ ai_gen_id }}.is-visible {
    display: block;
  }

  .dp-showcase__play-{{ ai_gen_id }}::after {
    content: "";
    position: absolute;
    left: 52%;
    top: 50%;
    transform: translate(-35%, -50%);
    border-top: 13px solid transparent;
    border-bottom: 13px solid transparent;
    border-left: 19px solid #fff;
  }

  .dp-showcase__counter-{{ ai_gen_id }} {
    position: absolute;
    left: 14px;
    bottom: 14px;
    z-index: 5;
    background: rgba(0,0,0,.75);
    color: #fff;
    border-radius: 999px;
    padding: 7px 11px;
    font-size: {{ block.settings.counter_size }}px;
    font-weight: {{ block.settings.counter_weight }};
    letter-spacing: {{ block.settings.counter_spacing }}px;
    line-height: 1;
  }

  .dp-showcase__zoom-{{ ai_gen_id }} {
    position: absolute;
    right: 12px;
    bottom: 12px;
    z-index: 5;
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 50%;
    background: #fff;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dp-showcase__zoom-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
  }

  .dp-showcase__thumbs-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.thumbs_per_row }}, 1fr);
    gap: {{ block.settings.thumb_gap }}px;
    margin-top: {{ block.settings.thumb_top_gap }}px;
  }

  .dp-showcase__thumb-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: {{ block.settings.thumb_aspect }};
    border: 2px solid transparent;
    border-radius: {{ block.settings.thumb_radius }}px;
    overflow: hidden;
    background: #111;
    cursor: pointer;
    padding: 0;
  }

  .dp-showcase__thumb-{{ ai_gen_id }}.is-active {
    border-color: {{ block.settings.accent_color }};
  }

  .dp-showcase__thumb-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dp-showcase__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    padding: 10px 0 4px;
  }

  .dp-showcase__dot-{{ ai_gen_id }} {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: {{ block.settings.border_color }};
    opacity: 0.25;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .dp-showcase__dot-{{ ai_gen_id }}.is-active {
    opacity: 1;
    transform: scale(1.3);
    background: {{ block.settings.accent_color }};
  }

  .dp-showcase__thumb-play-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 38px;
    height: 38px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: rgba(0,0,0,.65);
  }

  .dp-showcase__thumb-play-{{ ai_gen_id }}::after {
    content: "";
    position: absolute;
    left: 52%;
    top: 50%;
    transform: translate(-35%, -50%);
    border-top: 7px solid transparent;
    border-bottom: 7px solid transparent;
    border-left: 10px solid #fff;
  }

  .dp-showcase__info-{{ ai_gen_id }} {
    padding-top: {{ block.settings.info_top_padding }}px;
  }

  .dp-showcase__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_gap }}px;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    letter-spacing: {{ block.settings.title_spacing }}px;
    line-height: {{ block.settings.title_line_height }};
  }

  .dp-showcase__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: {{ block.settings.rating_gap }}px;
    font-size: {{ block.settings.rating_size }}px;
    font-weight: {{ block.settings.rating_weight }};
    letter-spacing: {{ block.settings.rating_spacing }}px;
    line-height: 1;
  }

  .dp-showcase__stars-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    letter-spacing: 1px;
  }

  .dp-showcase__trust-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.trust_gap }}px;
    font-size: {{ block.settings.trust_size }}px;
    font-weight: {{ block.settings.trust_weight }};
    letter-spacing: {{ block.settings.trust_spacing }}px;
    line-height: 1.25;
  }

  .dp-showcase__edition-label-{{ ai_gen_id }} {
    display: block;
    margin: 0 0 {{ block.settings.label_gap }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    letter-spacing: {{ block.settings.label_spacing }}px;
    line-height: 1;
    text-transform: uppercase;
  }

  .dp-showcase__variants-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.variant_gap }}px;
    margin-bottom: {{ block.settings.variant_bottom_gap }}px;
  }

  .dp-showcase__variant-{{ ai_gen_id }} {
    position: relative;
  }

  .dp-showcase__variant-{{ ai_gen_id }} input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .dp-showcase__variant-box-{{ ai_gen_id }} {
    min-height: {{ block.settings.variant_height }}px;
    border: 1px solid {{ block.settings.variant_border }};
    border-radius: {{ block.settings.variant_radius }}px;
    background: #fff;
    color: {{ block.settings.text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.variant_inner_gap }}px;
    padding: 6px 8px;
    cursor: pointer;
    text-align: center;
    text-transform: uppercase;
    font-size: {{ block.settings.variant_size }}px;
    font-weight: {{ block.settings.variant_weight }};
    letter-spacing: {{ block.settings.variant_spacing }}px;
    line-height: 1.05;
  }

  .dp-showcase__variant-box-{{ ai_gen_id }} img {
    width: {{ block.settings.variant_icon_width }}px;
    height: {{ block.settings.variant_icon_height }}px;
    object-fit: contain;
    display: block;
  }

  .dp-showcase__variant-{{ ai_gen_id }} input:checked + .dp-showcase__variant-box-{{ ai_gen_id }} {
    border-color: {{ block.settings.accent_color }};
    color: {{ block.settings.accent_color }};
    box-shadow: inset 0 0 0 1px {{ block.settings.accent_color }};
  }

  .dp-showcase__price-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.price_gap }}px;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    letter-spacing: {{ block.settings.price_spacing }}px;
    line-height: 1;
  }

  .dp-showcase__qty-label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: {{ block.settings.qty_label_gap }}px;
    font-size: {{ block.settings.qty_label_size }}px;
    font-weight: {{ block.settings.qty_label_weight }};
    letter-spacing: {{ block.settings.qty_label_spacing }}px;
    line-height: 1;
  }

  .dp-showcase__buy-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: {{ block.settings.buy_gap }}px;
    margin-bottom: {{ block.settings.buy_bottom_gap }}px;
  }

  .dp-showcase__qty-{{ ai_gen_id }} {
    height: {{ block.settings.button_height }}px;
    display: inline-flex;
    border: 1px solid {{ block.settings.input_border }};
    background: #fff;
  }

  .dp-showcase__qty-btn-{{ ai_gen_id }} {
    width: {{ block.settings.qty_button_width }}px;
    border: 0;
    background: transparent;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.qty_button_size }}px;
    font-weight: 400;
    cursor: pointer;
  }

  .dp-showcase__qty-input-{{ ai_gen_id }} {
    width: {{ block.settings.qty_input_width }}px;
    border: 0;
    border-left: 1px solid {{ block.settings.input_border }};
    border-right: 1px solid {{ block.settings.input_border }};
    text-align: center;
    background: transparent;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.qty_input_size }}px;
    font-weight: 400;
    -moz-appearance: textfield;
  }

  .dp-showcase__qty-input-{{ ai_gen_id }}::-webkit-inner-spin-button,
  .dp-showcase__qty-input-{{ ai_gen_id }}::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .dp-showcase__add-{{ ai_gen_id }} {
    width: 100%;
    min-height: {{ block.settings.button_height }}px;
    border: 0;
    border-radius: {{ block.settings.button_radius }}px;
    background: {{ block.settings.button_bg }};
    color: {{ block.settings.button_color }};
    cursor: pointer;
    text-transform: uppercase;
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    letter-spacing: {{ block.settings.button_spacing }}px;
    line-height: 1;
  }

  .dp-showcase__add-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg }};
  }

  .dp-showcase__add-{{ ai_gen_id }}:disabled {
    opacity: .55;
    cursor: not-allowed;
  }

  .dp-showcase__dynamic-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.dynamic_gap }}px;
  }

  .dp-showcase__dynamic-{{ ai_gen_id }} .shopify-payment-button__button {
    min-height: {{ block.settings.dynamic_height }}px;
    border-radius: {{ block.settings.dynamic_radius }}px;
  }

  .dp-showcase__payment-note-{{ ai_gen_id }} {
    display: block;
    text-align: center;
    color: {{ block.settings.payment_note_color }};
    font-size: {{ block.settings.payment_note_size }}px;
    font-weight: {{ block.settings.payment_note_weight }};
    letter-spacing: {{ block.settings.payment_note_spacing }}px;
    line-height: 1.2;
    text-decoration: underline;
    margin-bottom: {{ block.settings.payment_note_gap }}px;
  }

  .dp-showcase__features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid {{ block.settings.feature_border }};
  }

  .dp-showcase__feature-{{ ai_gen_id }} {
    min-height: {{ block.settings.feature_height }}px;
    border-right: 1px solid {{ block.settings.feature_border }};
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.feature_gap }}px;
    text-align: center;
    padding: {{ block.settings.feature_padding }}px;
    font-size: {{ block.settings.feature_size }}px;
    font-weight: {{ block.settings.feature_weight }};
    letter-spacing: {{ block.settings.feature_spacing }}px;
    line-height: {{ block.settings.feature_line_height }};
    color: {{ block.settings.text_color }};
  }

  .dp-showcase__feature-{{ ai_gen_id }}:last-child {
    border-right: 0;
  }

  .dp-showcase__feature-{{ ai_gen_id }} svg {
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    stroke: currentColor;
  }

  .dp-showcase__empty-{{ ai_gen_id }} {
    padding: 50px 20px;
    text-align: center;
    background: #f5f5f5;
  }

  @media screen and (max-width: 749px) {
    .dp-showcase-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_x }}px {{ block.settings.mobile_padding_bottom }}px;
      background: {{ block.settings.mobile_section_bg }};
    }

    .dp-showcase__wrap-{{ ai_gen_id }} {
      display: block;
      max-width: {{ block.settings.mobile_max_width }}px;
    }

    .dp-showcase__media-area-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.mobile_media_gap }}px;
    }

    .dp-showcase__main-media-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.mobile_media_aspect }};
      border-radius: {{ block.settings.mobile_media_radius }}px;
    }

    .dp-showcase__thumbs-{{ ai_gen_id }} {
      display: none;
    }

    .dp-showcase__play-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_play_size }}px;
      height: {{ block.settings.mobile_play_size }}px;
      border-width: 2px;
    }

    .dp-showcase__play-{{ ai_gen_id }}::after {
      border-top-width: 10px;
      border-bottom-width: 10px;
      border-left-width: 15px;
    }

    .dp-showcase__counter-{{ ai_gen_id }} {
      left: 10px;
      bottom: 10px;
      padding: 5px 8px;
      font-size: {{ block.settings.mobile_counter_size }}px;
    }

    .dp-showcase__zoom-{{ ai_gen_id }} {
      width: 30px;
      height: 30px;
      right: 10px;
      bottom: 10px;
    }

    .dp-showcase__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_title_size }}px;
      letter-spacing: {{ block.settings.mobile_title_spacing }}px;
      line-height: {{ block.settings.mobile_title_line_height }};
      margin-bottom: {{ block.settings.mobile_title_gap }}px;
    }

    .dp-showcase__rating-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_rating_size }}px;
      margin-bottom: {{ block.settings.mobile_rating_gap }}px;
    }

    .dp-showcase__trust-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_trust_size }}px;
      margin-bottom: {{ block.settings.mobile_trust_gap }}px;
    }

    .dp-showcase__edition-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_label_size }}px;
      margin-bottom: {{ block.settings.mobile_label_gap }}px;
    }

    .dp-showcase__variants-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_variant_gap }}px;
      margin-bottom: {{ block.settings.mobile_variant_bottom_gap }}px;
    }

    .dp-showcase__variant-box-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_variant_height }}px;
      font-size: {{ block.settings.mobile_variant_size }}px;
      gap: {{ block.settings.mobile_variant_inner_gap }}px;
      padding: 5px 6px;
    }

    .dp-showcase__variant-box-{{ ai_gen_id }} img {
      width: {{ block.settings.mobile_variant_icon_width }}px;
      height: {{ block.settings.mobile_variant_icon_height }}px;
    }

    .dp-showcase__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_price_size }}px;
      margin-bottom: {{ block.settings.mobile_price_gap }}px;
    }

    .dp-showcase__qty-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_qty_label_size }}px;
      margin-bottom: {{ block.settings.mobile_qty_label_gap }}px;
    }

    .dp-showcase__buy-row-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_buy_gap }}px;
      margin-bottom: {{ block.settings.mobile_buy_bottom_gap }}px;
    }

    .dp-showcase__qty-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_button_height }}px;
    }

    .dp-showcase__qty-btn-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_qty_button_width }}px;
      font-size: {{ block.settings.mobile_qty_button_size }}px;
    }

    .dp-showcase__qty-input-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_qty_input_width }}px;
      font-size: {{ block.settings.mobile_qty_input_size }}px;
    }

    .dp-showcase__add-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_button_height }}px;
      font-size: {{ block.settings.mobile_button_size }}px;
    }

    .dp-showcase__dynamic-{{ ai_gen_id }} .shopify-payment-button__button {
      min-height: {{ block.settings.mobile_dynamic_height }}px;
    }

    .dp-showcase__payment-note-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_payment_note_size }}px;
      margin-bottom: {{ block.settings.mobile_payment_note_gap }}px;
    }

    .dp-showcase__feature-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_feature_height }}px;
      padding: {{ block.settings.mobile_feature_padding }}px;
      font-size: {{ block.settings.mobile_feature_size }}px;
      gap: {{ block.settings.mobile_feature_gap }}px;
    }

    .dp-showcase__feature-{{ ai_gen_id }} svg {
      width: {{ block.settings.mobile_feature_icon_size }}px;
      height: {{ block.settings.mobile_feature_icon_size }}px;
    }
  }
  .dp-showcase__main-media-{{ ai_gen_id }},
.dp-showcase__slide-{{ ai_gen_id }},
.dp-showcase__thumb-{{ ai_gen_id }} {
  aspect-ratio: 1 / 1 !important;
}

.dp-showcase__image-{{ ai_gen_id }},
.dp-showcase__video-{{ ai_gen_id }},
.dp-showcase__external-video-{{ ai_gen_id }},
.dp-showcase__slide-{{ ai_gen_id }} iframe {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}
{% endstyle %}

<dp-showcase-{{ ai_gen_id }} class="dp-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if selected_product != blank %}
    {% assign current_variant = selected_product.selected_or_first_available_variant %}
    {% assign video_media = selected_product.media | where: 'media_type', 'video' %}
    {% assign external_video_media = selected_product.media | where: 'media_type', 'external_video' %}
    {% assign image_media = selected_product.media | where: 'media_type', 'image' %}
    {% assign media_count = video_media.size | plus: external_video_media.size | plus: image_media.size %}

    <div class="dp-showcase__wrap-{{ ai_gen_id }}">
      <div class="dp-showcase__media-area-{{ ai_gen_id }}">
        <div class="dp-showcase__main-media-{{ ai_gen_id }}">
          <div class="dp-showcase__track-{{ ai_gen_id }}" data-media-track>
            {% assign video_class = 'dp-showcase__video-' | append: ai_gen_id %}
            {% assign external_video_class = 'dp-showcase__external-video-' | append: ai_gen_id %}

            {% for media in video_media %}
              <div class="dp-showcase__slide-{{ ai_gen_id }}" data-media-slide data-media-type="video" data-media-id="{{ media.id }}">
                {{ media | video_tag: controls: false, muted: true, autoplay: true, loop: true, playsinline: true, preload: 'auto', class: video_class }}
              </div>
            {% endfor %}

            {% for media in external_video_media %}
              <div class="dp-showcase__slide-{{ ai_gen_id }}" data-media-slide data-media-type="video" data-media-id="{{ media.id }}">
                {{ media | external_video_tag: class: external_video_class }}
              </div>
            {% endfor %}

            {% for media in image_media %}
              <div class="dp-showcase__slide-{{ ai_gen_id }}" data-media-slide data-media-type="image" data-media-id="{{ media.id }}">
                <img
                  src="{{ media.preview_image | image_url: width: 1600 }}"
                  alt="{{ media.alt | escape }}"
                  class="dp-showcase__image-{{ ai_gen_id }}"
                  loading="{% if forloop.first and video_media.size == 0 and external_video_media.size == 0 %}eager{% else %}lazy{% endif %}"
                  width="{{ media.preview_image.width }}"
                  height="{{ media.preview_image.height }}"
                >
              </div>
            {% endfor %}

            {% if media_count == 0 and selected_product.featured_image %}
              {% assign media_count = 1 %}
              <div class="dp-showcase__slide-{{ ai_gen_id }}" data-media-slide data-media-type="image" data-media-id="{{ selected_product.featured_media.id }}">
                <img
                  src="{{ selected_product.featured_image | image_url: width: 1600 }}"
                  alt="{{ selected_product.featured_image.alt | escape }}"
                  class="dp-showcase__image-{{ ai_gen_id }}"
                  loading="eager"
                  width="{{ selected_product.featured_image.width }}"
                  height="{{ selected_product.featured_image.height }}"
                >
              </div>
            {% endif %}
          </div>

          {% if block.settings.show_center_play %}
            <span class="dp-showcase__play-{{ ai_gen_id }}" aria-hidden="true" data-center-play></span>
          {% endif %}

          {% if block.settings.show_counter %}
            <span class="dp-showcase__counter-{{ ai_gen_id }}" data-media-counter>1/{{ media_count }}</span>
          {% endif %}

          {% if block.settings.show_zoom %}
            <button class="dp-showcase__zoom-{{ ai_gen_id }}" type="button" aria-label="Zoom image">
              <svg viewBox="0 0 24 24" fill="none">
                <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
                <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            </button>
          {% endif %}
        </div>

        {% if media_count > 1 %}
          <div class="dp-showcase__dots-{{ ai_gen_id }}" data-media-dots>
            {% assign dot_index = 0 %}
            {% for media in video_media %}
              {% assign dot_index = dot_index | plus: 1 %}
              <button class="dp-showcase__dot-{{ ai_gen_id }} {% if dot_index == 1 %}is-active{% endif %}" type="button" data-media-thumb data-index="{{ dot_index | minus: 1 }}" aria-label="Slide {{ dot_index }}"></button>
            {% endfor %}
            {% for media in external_video_media %}
              {% assign dot_index = dot_index | plus: 1 %}
              <button class="dp-showcase__dot-{{ ai_gen_id }} {% if dot_index == 1 %}is-active{% endif %}" type="button" data-media-thumb data-index="{{ dot_index | minus: 1 }}" aria-label="Slide {{ dot_index }}"></button>
            {% endfor %}
            {% for media in image_media %}
              {% assign dot_index = dot_index | plus: 1 %}
              <button class="dp-showcase__dot-{{ ai_gen_id }}" type="button" data-media-thumb data-index="{{ dot_index | minus: 1 }}" aria-label="Slide {{ dot_index }}"></button>
            {% endfor %}
          </div>

          <div class="dp-showcase__thumbs-{{ ai_gen_id }}">
            {% assign thumb_index = 0 %}

            {% for media in video_media %}
              {% assign thumb_index = thumb_index | plus: 1 %}
              <button class="dp-showcase__thumb-{{ ai_gen_id }} {% if thumb_index == 1 %}is-active{% endif %}" type="button" data-media-thumb data-index="{{ thumb_index | minus: 1 }}">
                {% if media.preview_image %}
                  <img src="{{ media.preview_image | image_url: width: 300 }}" alt="{{ selected_product.title | escape }}" loading="lazy">
                {% endif %}
                <span class="dp-showcase__thumb-play-{{ ai_gen_id }}"></span>
              </button>
            {% endfor %}

            {% for media in external_video_media %}
              {% assign thumb_index = thumb_index | plus: 1 %}
              <button class="dp-showcase__thumb-{{ ai_gen_id }} {% if thumb_index == 1 %}is-active{% endif %}" type="button" data-media-thumb data-index="{{ thumb_index | minus: 1 }}">
                {% if media.preview_image %}
                  <img src="{{ media.preview_image | image_url: width: 300 }}" alt="{{ selected_product.title | escape }}" loading="lazy">
                {% endif %}
                <span class="dp-showcase__thumb-play-{{ ai_gen_id }}"></span>
              </button>
            {% endfor %}

            {% for media in image_media %}
              {% assign thumb_index = thumb_index | plus: 1 %}
              <button class="dp-showcase__thumb-{{ ai_gen_id }} {% if thumb_index == 1 %}is-active{% endif %}" type="button" data-media-thumb data-index="{{ thumb_index | minus: 1 }}">
                <img src="{{ media.preview_image | image_url: width: 300 }}" alt="{{ media.alt | escape }}" loading="lazy">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="dp-showcase__info-{{ ai_gen_id }}">
        <h1 class="dp-showcase__title-{{ ai_gen_id }}">{{ selected_product.title }}</h1>

        {% if block.settings.show_rating %}
          {% assign dynamic_review_count = selected_product.metafields.reviews.rating_count | default: block.settings.review_count %}
          <div class="dp-showcase__rating-{{ ai_gen_id }}">
            <span class="dp-showcase__stars-{{ ai_gen_id }}">★★★★★</span>
            <span>({{ dynamic_review_count }} reviews)</span>
          </div>
        {% endif %}

        {% if block.settings.trust_text != blank %}
          <p class="dp-showcase__trust-{{ ai_gen_id }}">{{ block.settings.trust_text }}</p>
        {% endif %}

        {% form 'product', selected_product %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

          {% if selected_product.variants.size > 1 %}
            <span class="dp-showcase__edition-label-{{ ai_gen_id }}">{{ block.settings.edition_label }}</span>

            <div class="dp-showcase__variants-{{ ai_gen_id }}">
              {% for variant in selected_product.variants limit: 4 %}
                <label class="dp-showcase__variant-{{ ai_gen_id }}">
                  <input
                    type="radio"
                    name="edition-option-{{ ai_gen_id }}"
                    value="{{ variant.id }}"
                    data-variant-radio
                    data-price-html="{{ variant.price | money | escape }}"
                    data-available="{{ variant.available }}"
                    data-url="{{ selected_product.url }}?variant={{ variant.id }}"
                    data-featured-media-id="{% if variant.featured_media %}{{ variant.featured_media.id }}{% elsif variant.image %}{{ variant.image.id }}{% endif %}"
                    {% if variant.id == current_variant.id %}checked{% endif %}
                  >

                  {% liquid
                    assign variant_icon = blank
                    case forloop.index
                      when 1
                        assign variant_icon = block.settings.variant_1_icon
                      when 2
                        assign variant_icon = block.settings.variant_2_icon
                      when 3
                        assign variant_icon = block.settings.variant_3_icon
                      when 4
                        assign variant_icon = block.settings.variant_4_icon
                    endcase
                  %}

                  <span class="dp-showcase__variant-box-{{ ai_gen_id }}">
                    {% if variant_icon != blank %}
                      <img
                        src="{{ variant_icon | image_url: width: 160 }}"
                        alt="{{ variant.title | escape }}"
                        loading="lazy"
                        width="160"
                        height="80"
                      >
                    {% endif %}
                    <span>{{ variant.title }}</span>
                  </span>
                </label>
              {% endfor %}
            </div>
          {% endif %}

          <p class="dp-showcase__price-{{ ai_gen_id }}" data-product-price>{{ current_variant.price | money }}</p>

          <label class="dp-showcase__qty-label-{{ ai_gen_id }}" for="Quantity-{{ ai_gen_id }}">
            {{ block.settings.quantity_label }}
          </label>

          <div class="dp-showcase__buy-row-{{ ai_gen_id }}">
            <div class="dp-showcase__qty-{{ ai_gen_id }}">
              <button type="button" class="dp-showcase__qty-btn-{{ ai_gen_id }}" data-qty-minus aria-label="Decrease quantity">−</button>
              <input id="Quantity-{{ ai_gen_id }}" class="dp-showcase__qty-input-{{ ai_gen_id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
              <button type="button" class="dp-showcase__qty-btn-{{ ai_gen_id }}" data-qty-plus aria-label="Increase quantity">+</button>
            </div>

            <button
              type="submit"
              name="add"
              class="dp-showcase__add-{{ ai_gen_id }}"
              data-add-button
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {% if current_variant.available %}
                {{ block.settings.button_text }}
              {% else %}
                Sold out
              {% endif %}
            </button>
          </div>

          {% if block.settings.show_dynamic_checkout %}
            <div class="dp-showcase__dynamic-{{ ai_gen_id }}">
              {{ form | payment_button }}
            </div>
          {% endif %}
        {% endform %}

        {% if block.settings.payment_note != blank %}
          <span class="dp-showcase__payment-note-{{ ai_gen_id }}">{{ block.settings.payment_note }}</span>
        {% endif %}

        {% if block.settings.show_features %}
          <div class="dp-showcase__features-{{ ai_gen_id }}">
            <div class="dp-showcase__feature-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3Z" stroke-width="1.8"/><path d="M9 12l2 2 4-5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>{{ block.settings.feature_1 }}</span>
            </div>

            <div class="dp-showcase__feature-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4" stroke-width="1.8"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3" stroke-width="1.8" stroke-linecap="round"/></svg>
              <span>{{ block.settings.feature_2 }}</span>
            </div>

            <div class="dp-showcase__feature-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 12a7 7 0 0 1 14 0v4a3 3 0 0 1-3 3h-1" stroke-width="1.8"/><path d="M5 12v4h3v-5H5Zm14 0v4h-3v-5h3Z" stroke-width="1.8"/></svg>
              <span>{{ block.settings.feature_3 }}</span>
            </div>

            <div class="dp-showcase__feature-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 4l2.2 4.6 5 .7-3.6 3.5.8 5-4.4-2.4-4.4 2.4.8-5L4.8 9.3l5-.7L12 4Z" stroke-width="1.8" stroke-linejoin="round"/></svg>
              <span>{{ block.settings.feature_4 }}</span>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="dp-showcase__empty-{{ ai_gen_id }}">Select a product.</div>
  {% endif %}
</dp-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class DPShowcase{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        const track = this.querySelector('[data-media-track]');
        const slides = this.querySelectorAll('[data-media-slide]');
        const thumbs = this.querySelectorAll('[data-media-thumb]');
        const counter = this.querySelector('[data-media-counter]');
        const centerPlay = this.querySelector('[data-center-play]');

        const qtyInput = this.querySelector('input[name="quantity"]');
        const minus = this.querySelector('[data-qty-minus]');
        const plus = this.querySelector('[data-qty-plus]');
        const variantInput = this.querySelector('[data-variant-id-input]');
        const price = this.querySelector('[data-product-price]');
        const addButton = this.querySelector('[data-add-button]');
        const radios = this.querySelectorAll('[data-variant-radio]');

        const updateMedia = () => {
          if (!track || !slides.length) return;

          const width = slides[0].offsetWidth || track.clientWidth;
          const rawIndex = Math.round(track.scrollLeft / width);
          const index = Math.max(0, Math.min(slides.length - 1, rawIndex));
          const activeSlide = slides[index];
          const activeType = activeSlide ? activeSlide.dataset.mediaType : '';

          if (counter) counter.textContent = (index + 1) + '/' + slides.length;

          thumbs.forEach((thumb, i) => {
            thumb.classList.toggle('is-active', i === index);
          });

          if (centerPlay) {
            centerPlay.classList.toggle('is-visible', activeType === 'video');
          }
        };

        const goToMedia = (index) => {
          if (!track || !slides.length) return;

          const width = slides[0].offsetWidth || track.clientWidth;
          track.scrollTo({
            left: width * index,
            behavior: 'smooth'
          });
        };

        thumbs.forEach((thumb) => {
          thumb.addEventListener('click', () => {
            goToMedia(parseInt(thumb.dataset.index || '0', 10));
          });
        });

        if (track) {
          track.addEventListener('scroll', () => window.requestAnimationFrame(updateMedia));
          window.addEventListener('resize', updateMedia);
          updateMedia();
        }

        if (minus && qtyInput) {
          minus.addEventListener('click', () => {
            const current = parseInt(qtyInput.value || '1', 10);
            qtyInput.value = Math.max(1, current - 1);
          });
        }

        if (plus && qtyInput) {
          plus.addEventListener('click', () => {
            const current = parseInt(qtyInput.value || '1', 10);
            qtyInput.value = current + 1;
          });
        }

        radios.forEach((radio) => {
          radio.addEventListener('change', () => {
            if (!radio.checked) return;

            const available = radio.dataset.available === 'true';

            if (variantInput) {
              variantInput.value = radio.value;
            }

            if (price) {
              price.innerHTML = radio.dataset.priceHtml || '';
            }

            if (addButton) {
              addButton.disabled = !available;
              addButton.textContent = available ? '{{ block.settings.button_text | escape }}' : 'Sold out';
            }

            const featuredMediaId = radio.dataset.featuredMediaId;

            if (featuredMediaId && slides.length) {
              const targetIndex = Array.from(slides).findIndex((slide) => {
                return slide.dataset.mediaId === featuredMediaId;
              });

              if (targetIndex > -1) {
                goToMedia(targetIndex);
              }
            }

            if (radio.dataset.url) {
              window.history.replaceState({}, '', radio.dataset.url);
            }
          });
        });

        const urlVariantId = new URLSearchParams(window.location.search).get('variant');

        if (urlVariantId) {
          const matchingRadio = Array.from(radios).find((radio) => radio.value === urlVariantId);

          if (matchingRadio) {
            matchingRadio.checked = true;
            matchingRadio.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      }
    }

    if (!customElements.get('dp-showcase-{{ ai_gen_id }}')) {
      customElements.define('dp-showcase-{{ ai_gen_id }}', DPShowcase{{ ai_gen_id }});
    }
  })();
</script>

