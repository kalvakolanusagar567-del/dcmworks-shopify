    { "type": "text", "id": "edition_label", "label": "Edition label", "default": "Choose your edition" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "button_text", "label": "Add button text", "default": "Add to cart" },
    { "type": "text", "id": "payment_note", "label": "Payment note", "default": "More payment options" },

    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout", "default": true },
