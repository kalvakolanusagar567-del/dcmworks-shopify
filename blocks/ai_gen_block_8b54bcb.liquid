{% doc %}
  @prompt
    SPECIFICATIONS
    Product specifications from product metafields.
    Desktop 4 columns, mobile stacked rows with label left and value right.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-specs-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_x }}px {{ block.settings.section_padding_bottom }}px;
    border-top: {% if block.settings.show_top_border %}{{ block.settings.top_border_width }} solid {{ block.settings.border_color }}{% else %}none{% endif %};
    border-bottom: {% if block.settings.show_bottom_border %}{{ block.settings.bottom_border_width }} solid {{ block.settings.border_color }}{% else %}none{% endif %};
    box-sizing: border-box;
  }

  .ai-specs__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-specs__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_bottom_spacing }}px;
    font-family: {{ block.settings.heading_font_family }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    line-height: 1;
    text-transform: uppercase;
  }

  .ai-specs__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    column-gap: {{ block.settings.column_gap }}px;
    row-gap: {{ block.settings.row_gap }}px;
  }

  .ai-specs__item-{{ ai_gen_id }} {
    min-width: 0;
  }

  .ai-specs__label-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.label_bottom_spacing }}px;
    font-family: {{ block.settings.label_font_family }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    letter-spacing: {{ block.settings.label_letter_spacing }};
    line-height: 1;
    text-transform: uppercase;
  }

  .ai-specs__value-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.value_font_family }};
    font-size: {{ block.settings.value_size }}px;
    font-weight: {{ block.settings.value_weight }};
    color: {{ block.settings.value_color }};
    letter-spacing: {{ block.settings.value_letter_spacing }};
    line-height: {{ block.settings.value_line_height }};
  }

  @media screen and (max-width: 989px) {
    .ai-specs__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: {{ block.settings.tablet_row_gap }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-specs-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_x }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-specs__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      margin-bottom: {{ block.settings.mobile_heading_bottom_spacing }}px;
    }

    .ai-specs__grid-{{ ai_gen_id }} {
      display: block;
      border-top: {{ block.settings.mobile_row_border_width }} solid {{ block.settings.mobile_row_border_color }};
    }

    .ai-specs__item-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: {{ block.settings.mobile_row_gap }}px;
      padding: {{ block.settings.mobile_row_padding_y }}px 0;
      border-bottom: {{ block.settings.mobile_row_border_width }} solid {{ block.settings.mobile_row_border_color }};
    }

    .ai-specs__label-{{ ai_gen_id }} {
      margin: 0;
      font-size: {{ block.settings.mobile_label_size }}px;
      line-height: 1;
      flex: 0 0 auto;
    }

    .ai-specs__value-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_value_size }}px;
      line-height: {{ block.settings.mobile_value_line_height }};
      text-align: right;
      flex: 1 1 auto;
    }
  }
{% endstyle %}

{% liquid
  assign specs = product.metafields.custom
  assign has_specs = false

  if specs.platform != blank or specs.scale != blank or specs.motion != blank or specs.power != blank or specs.lighting != blank or specs.mounts != blank or specs.recommended != blank or specs.warranty != blank
    assign has_specs = true
  endif
%}

{% if has_specs %}
  <div class="ai-specs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-specs__inner-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <div class="ai-specs__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </div>
      {% endif %}

      <div class="ai-specs__grid-{{ ai_gen_id }}">
        {% if specs.platform != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Platform</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.platform }}</p>
          </div>
        {% endif %}

        {% if specs.scale != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Scale</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.scale }}</p>
          </div>
        {% endif %}

        {% if specs.motion != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Motion</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.motion }}</p>
          </div>
        {% endif %}

        {% if specs.power != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Power</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.power }}</p>
          </div>
        {% endif %}

        {% if specs.lighting != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Lighting</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.lighting }}</p>
          </div>
        {% endif %}

        {% if specs.mounts != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Mounts</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.mounts }}</p>
          </div>
        {% endif %}

        {% if specs.recommended != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Recommended</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.recommended }}</p>
          </div>
        {% endif %}

        {% if specs.warranty != blank %}
          <div class="ai-specs__item-{{ ai_gen_id }}">
            <p class="ai-specs__label-{{ ai_gen_id }}">Warranty</p>
            <p class="ai-specs__value-{{ ai_gen_id }}">{{ specs.warranty }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

