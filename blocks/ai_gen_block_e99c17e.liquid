{% doc %}
  @prompt
    FEATURES
    A Continuous, silent motor
    B Built-in lighting
    C Fits 1:64 — every brand
    D Set-and-forget
    4 columns desktop, bordered stacked rows on mobile.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_x }}px {{ block.settings.section_padding_bottom }}px;
    box-sizing: border-box;
  }

  .ai-features-grid__section-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.section_label_font_family }};
    font-size: {{ block.settings.section_label_size }}px;
    font-weight: {{ block.settings.section_label_weight }};
    color: {{ block.settings.section_label_color }};
    letter-spacing: {{ block.settings.section_label_letter_spacing }};
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 {{ block.settings.section_label_bottom_spacing }}px;
  }

  .ai-features-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: {{ block.settings.column_gap }}px;
    width: 100%;
  }

  .ai-features-grid__item-{{ ai_gen_id }} {
    min-width: 0;
  }

  .ai-features-grid__label-{{ ai_gen_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 999px;
    border: {{ block.settings.circle_border_width }} solid {{ block.settings.circle_border_color }};
    background: {{ block.settings.circle_background }};
    color: {{ block.settings.label_color }};
    font-family: {{ block.settings.label_font_family }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    margin: 0 0 {{ block.settings.circle_bottom_spacing }}px;
    text-transform: uppercase;
  }

  .ai-features-grid__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font_family }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_bottom_spacing }}px;
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
  }

  .ai-features-grid__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font_family }};
    font-size: {{ block.settings.description_size }}px;
    font-weight: {{ block.settings.description_weight }};
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: {{ block.settings.description_line_height }};
    letter-spacing: {{ block.settings.description_letter_spacing }};
  }

  @media screen and (max-width: 989px) {
    .ai-features-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: {{ block.settings.tablet_row_gap }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-features-grid-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.mobile_section_padding_top }}px {{ block.settings.mobile_section_padding_x }}px {{ block.settings.mobile_section_padding_bottom }}px;
      border-top: {{ block.settings.mobile_section_border_width }} solid {{ block.settings.mobile_section_border_color }};
      border-bottom: {{ block.settings.mobile_section_border_width }} solid {{ block.settings.mobile_section_border_color }};
    }

    .ai-features-grid__section-label-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.mobile_section_label_bottom_spacing }}px;
      font-size: {{ block.settings.mobile_section_label_size }}px;
    }

    .ai-features-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 0;
      border-top: {{ block.settings.mobile_item_border_width }} solid {{ block.settings.mobile_item_border_color }};
    }

    .ai-features-grid__item-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: {{ block.settings.mobile_circle_column_width }}px 1fr;
      column-gap: {{ block.settings.mobile_text_gap }}px;
      align-items: start;
      padding: {{ block.settings.mobile_item_padding_y }}px 0;
      border-bottom: {{ block.settings.mobile_item_border_width }} solid {{ block.settings.mobile_item_border_color }};
    }

    .ai-features-grid__label-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 1 / 3;
      margin: 0;
      width: {{ block.settings.mobile_circle_size }}px;
      height: {{ block.settings.mobile_circle_size }}px;
      font-size: {{ block.settings.mobile_label_size }}px;
    }

    .ai-features-grid__heading-{{ ai_gen_id }} {
      grid-column: 2;
      grid-row: 1;
      font-size: {{ block.settings.mobile_heading_size }}px;
      margin: 0 0 {{ block.settings.mobile_heading_bottom_spacing }}px;
    }

    .ai-features-grid__description-{{ ai_gen_id }} {
      grid-column: 2;
      grid-row: 2;
      font-size: {{ block.settings.mobile_description_size }}px;
    }
  }
{% endstyle %}

<div class="ai-features-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_label != blank %}
    <div class="ai-features-grid__section-label-{{ ai_gen_id }}">
      {{ block.settings.section_label }}
    </div>
  {% endif %}

  <div class="ai-features-grid__container-{{ ai_gen_id }}">
    {% if block.settings.feature_a_enabled %}
      <div class="ai-features-grid__item-{{ ai_gen_id }}">
        <div class="ai-features-grid__label-{{ ai_gen_id }}">{{ block.settings.feature_a_label }}</div>
        <h3 class="ai-features-grid__heading-{{ ai_gen_id }}">{{ block.settings.feature_a_heading }}</h3>
        <p class="ai-features-grid__description-{{ ai_gen_id }}">{{ block.settings.feature_a_description }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_b_enabled %}
      <div class="ai-features-grid__item-{{ ai_gen_id }}">
        <div class="ai-features-grid__label-{{ ai_gen_id }}">{{ block.settings.feature_b_label }}</div>
        <h3 class="ai-features-grid__heading-{{ ai_gen_id }}">{{ block.settings.feature_b_heading }}</h3>
        <p class="ai-features-grid__description-{{ ai_gen_id }}">{{ block.settings.feature_b_description }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_c_enabled %}
      <div class="ai-features-grid__item-{{ ai_gen_id }}">
        <div class="ai-features-grid__label-{{ ai_gen_id }}">{{ block.settings.feature_c_label }}</div>
        <h3 class="ai-features-grid__heading-{{ ai_gen_id }}">{{ block.settings.feature_c_heading }}</h3>
        <p class="ai-features-grid__description-{{ ai_gen_id }}">{{ block.settings.feature_c_description }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_d_enabled %}
      <div class="ai-features-grid__item-{{ ai_gen_id }}">
        <div class="ai-features-grid__label-{{ ai_gen_id }}">{{ block.settings.feature_d_label }}</div>
        <h3 class="ai-features-grid__heading-{{ ai_gen_id }}">{{ block.settings.feature_d_heading }}</h3>
        <p class="ai-features-grid__description-{{ ai_gen_id }}">{{ block.settings.feature_d_description }}</p>
      </div>
    {% endif %}
  </div>
</div>

