            <span class="ai-sidebar-box-{{ ai_gen_id }}"></span>
            <span class="ai-sidebar-label-{{ ai_gen_id }}">S02 · Garage</span>
            <span class="ai-sidebar-count-{{ ai_gen_id }}" data-count-for="series:s02-garage">0</span>
          </div>

          <div class="ai-sidebar-option-{{ ai_gen_id }}" data-filter-group="series" data-filter-value="accessories">
            <span class="ai-sidebar-box-{{ ai_gen_id }}"></span>
