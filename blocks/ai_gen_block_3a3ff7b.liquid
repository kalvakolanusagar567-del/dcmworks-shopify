</editorial-filter-sidebar-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialFilterSidebar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.selected = {};
      }

      connectedCallback() {
        this.options = Array.from(this.querySelectorAll('[data-filter-group][data-filter-value]'));
        this.resetButton = this.querySelector('[data-reset]');
        this.activeCount = this.querySelector('.ai-sidebar-active-count-{{ ai_gen_id }}');

        this.options.forEach((option) => {
          option.addEventListener('click', () => this.toggleOption(option));
        });

        if (this.resetButton) {
          this.resetButton.addEventListener('click', () => this.reset());
        }

        window.addEventListener('editorialProductCounts', (event) => {
          this.updateCounts(event.detail.counts || {});
        });

        window.dispatchEvent(new CustomEvent('editorialFiltersReady'));
      }

      toggleOption(option) {
        const group = option.dataset.filterGroup;
        const value = option.dataset.filterValue;

        if (value === 'all') {
          delete this.selected[group];

          this.options
            .filter((item) => item.dataset.filterGroup === group)
            .forEach((item) => item.classList.remove('is-checked'));
        } else {
          if (!this.selected[group]) {
            this.selected[group] = [];
          }

          const index = this.selected[group].indexOf(value);

          if (index > -1) {
            this.selected[group].splice(index, 1);
            option.classList.remove('is-checked');
          } else {
            this.selected[group].push(value);
            option.classList.add('is-checked');
          }

          if (this.selected[group].length === 0) {
            delete this.selected[group];
          }

          this.options
            .filter((item) => item.dataset.filterGroup === group && item.dataset.filterValue === 'all')
            .forEach((item) => item.classList.remove('is-checked'));
        }

        this.dispatchFilters();
      }

      reset() {
        this.selected = {};
        this.options.forEach((option) => option.classList.remove('is-checked'));
        this.dispatchFilters();
      }

      dispatchFilters() {
        let count = 0;

        Object.keys(this.selected).forEach((group) => {
          count += this.selected[group].length;
        });

        if (this.activeCount) {
          this.activeCount.textContent = '+ ' + count;
        }

        window.dispatchEvent(new CustomEvent('editorialFiltersChanged', {
          detail: {
            filters: this.selected
          }
        }));
      }

      updateCounts(counts) {
        this.options.forEach((option) => {
          const group = option.dataset.filterGroup;
          const value = option.dataset.filterValue;
          const key = group + ':' + value;
          const countEl = this.querySelector('[data-count-for="' + key + '"]');

          if (!countEl) return;

          const count = counts[key] || 0;
          countEl.textContent = count;

          if (value !== 'all') {
            option.classList.toggle('is-disabled', count === 0);
          }
        });
      }
    }

    customElements.define('editorial-filter-sidebar-{{ ai_gen_id }}', EditorialFilterSidebar{{ ai_gen_id }});
  })();
</script>

