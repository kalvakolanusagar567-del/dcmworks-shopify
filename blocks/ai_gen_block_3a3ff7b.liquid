{% doc %}
  @prompt
    Dynamic editorial sidebar filters.
    Desktop vertical sidebar.
    Mobile horizontal top filter bar.
    Sends selected filters to product grid.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @media screen and (min-width: 750px) {
    .shopify-block:has([data-editorial-sidebar]) {
      float: left;
      width: {{ block.settings.sidebar_width }}px;
      position: relative;
      z-index: 2;
    }
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    border-top: 1px solid {{ block.settings.border_color }};
    border-right: 1px solid {{ block.settings.text_color }};
    padding: {{ block.settings.desktop_padding_top }}px {{ block.settings.desktop_padding_x }}px {{ block.settings.desktop_padding_bottom }}px;
    box-sizing: border-box;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} *,
  .ai-editorial-sidebar-{{ ai_gen_id }} *::before,
  .ai-editorial-sidebar-{{ ai_gen_id }} *::after {
    box-sizing: border-box;
  }

  .ai-sidebar-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 22px;
    gap: 10px;
  }

  .ai-sidebar-title-wrap-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ai-sidebar-title-{{ ai_gen_id }},
  .ai-sidebar-active-count-{{ ai_gen_id }},
  .ai-sidebar-group-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1;
    letter-spacing: {{ block.settings.heading_spacing }}px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .ai-sidebar-active-count-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
  }

  .ai-sidebar-scroll-{{ ai_gen_id }} {
    display: block;
  }

  .ai-sidebar-group-{{ ai_gen_id }} {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-sidebar-group-title-{{ ai_gen_id }} {
    margin-bottom: 14px;
  }

  .ai-sidebar-options-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-sidebar-option-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 12px minmax(0, 1fr) auto;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    user-select: none;
  }

  .ai-sidebar-box-{{ ai_gen_id }} {
    width: 11px;
    height: 11px;
    border: 1px solid {{ block.settings.text_color }};
    display: block;
    position: relative;
    background: transparent;
  }

  .ai-sidebar-option-{{ ai_gen_id }}.is-checked .ai-sidebar-box-{{ ai_gen_id }} {
    background: {{ block.settings.text_color }};
  }

  .ai-sidebar-option-{{ ai_gen_id }}.is-checked .ai-sidebar-box-{{ ai_gen_id }}::after {
    content: "";
    position: absolute;
    left: 3px;
    top: 1px;
    width: 3px;
    height: 6px;
    border: solid {{ block.settings.background_color }};
    border-width: 0 1px 1px 0;
    transform: rotate(45deg);
  }

  .ai-sidebar-label-{{ ai_gen_id }},
  .ai-sidebar-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.option_size }}px;
    line-height: 1.15;
  }

  .ai-sidebar-count-{{ ai_gen_id }} {
    color: {{ block.settings.muted_color }};
    text-align: right;
    min-width: 16px;
  }

  .ai-sidebar-option-{{ ai_gen_id }}.is-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .ai-sidebar-reset-{{ ai_gen_id }} {
    width: 100%;
    border: 1px solid {{ block.settings.text_color }};
    background: transparent;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    padding: 12px 10px;
    font-size: {{ block.settings.reset_size }}px;
    letter-spacing: {{ block.settings.reset_spacing }}px;
    line-height: 1;
    text-transform: uppercase;
    font-weight: 700;
  }

  .ai-sidebar-reset-{{ ai_gen_id }}:hover {
    background: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
  }

  @media screen and (max-width: 749px) {
    .shopify-block:has([data-editorial-sidebar]) {
      float: none !important;
      width: 100% !important;
      clear: both !important;
      margin: 0 !important;
    }

    .ai-editorial-sidebar-{{ ai_gen_id }} {
      width: 100% !important;
      border-top: 1px solid {{ block.settings.border_color }};
      border-right: 0 !important;
      border-bottom: 1px solid {{ block.settings.border_color }};
      padding: 0 !important;
      overflow: hidden;
      background: {{ block.settings.background_color }};
    }

    .ai-sidebar-mobile-top-{{ ai_gen_id }} {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 8px 8px;
      border-bottom: 1px solid {{ block.settings.border_color }};
    }

    .ai-sidebar-header-{{ ai_gen_id }} {
      width: auto;
      min-width: 0;
      margin: 0;
      flex: 1;
    }

    .ai-sidebar-title-wrap-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-sidebar-title-{{ ai_gen_id }},
    .ai-sidebar-active-count-{{ ai_gen_id }} {
      font-size: 8px !important;
      letter-spacing: 4px !important;
      line-height: 1;
    }

    .ai-sidebar-mobile-sort-{{ ai_gen_id }} {
      display: flex !important;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      font-size: 8px;
      letter-spacing: 4px;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .ai-sidebar-mobile-icons-{{ ai_gen_id }} {
      display: flex;
      gap: 5px;
    }

    .ai-sidebar-mobile-icon-{{ ai_gen_id }} {
      width: 19px;
      height: 19px;
      border: 1px solid {{ block.settings.text_color }};
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      line-height: 1;
    }

    .ai-sidebar-mobile-icon-{{ ai_gen_id }}.active {
      background: {{ block.settings.text_color }};
      color: {{ block.settings.background_color }};
    }

    .ai-sidebar-scroll-wrap-{{ ai_gen_id }} {
      overflow-x: auto;
      overflow-y: hidden;
      width: 100%;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
      padding: 8px 8px;
    }

    .ai-sidebar-scroll-wrap-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-sidebar-scroll-{{ ai_gen_id }} {
      display: flex;
      align-items: flex-start;
      gap: 22px;
      width: max-content;
      padding-bottom: 8px;
    }

    .ai-sidebar-scroll-wrap-{{ ai_gen_id }}::after {
      content: "";
      display: block;
      width: 190px;
      height: 10px;
      border-radius: 999px;
      background: {{ block.settings.mobile_scrollbar_color }};
      margin-top: 8px;
    }

    .ai-sidebar-group-{{ ai_gen_id }} {
      min-width: 145px;
      margin: 0;
      padding: 0 22px 0 0;
      border-bottom: 0;
      border-right: 1px solid {{ block.settings.border_color }};
    }

    .ai-sidebar-group:last-of-type {
      border-right: 0;
    }

    .ai-sidebar-group-title-{{ ai_gen_id }} {
      font-size: 8px !important;
      letter-spacing: 4px !important;
      margin-bottom: 10px;
    }

    .ai-sidebar-options-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-sidebar-option-{{ ai_gen_id }} {
      grid-template-columns: 11px minmax(0, 1fr) auto;
      gap: 7px;
    }

    .ai-sidebar-label-{{ ai_gen_id }},
    .ai-sidebar-count-{{ ai_gen_id }} {
      font-size: 10px !important;
    }

    .ai-sidebar-box-{{ ai_gen_id }} {
      width: 10px;
      height: 10px;
    }

    .ai-sidebar-reset-{{ ai_gen_id }} {
      width: 145px;
      flex: 0 0 auto;
      align-self: flex-start;
      padding: 10px 8px;
      font-size: 8px !important;
      letter-spacing: 2px !important;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-sidebar-mobile-sort-{{ ai_gen_id }} {
      display: none !important;
    }

    .ai-sidebar-scroll-wrap-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<editorial-filter-sidebar-{{ ai_gen_id }}
