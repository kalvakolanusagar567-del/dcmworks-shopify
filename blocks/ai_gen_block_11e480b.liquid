{% doc %}
  @prompt
    Horizontal timeline with fully customizable typography, colors, spacing, desktop and mobile controls.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  {{ block.settings.kicker_font | font_face }}
  {{ block.settings.heading_font | font_face }}
  {{ block.settings.date_font | font_face }}
  {{ block.settings.milestone_title_font | font_face }}
  {{ block.settings.description_font | font_face }}

  .ai-timeline-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.desktop_padding_top }}px;
    padding-bottom: {{ block.settings.desktop_padding_bottom }}px;
    padding-left: {{ block.settings.desktop_padding_left }}px;
    padding-right: {{ block.settings.desktop_padding_right }}px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
   
  }

  .ai-timeline-kicker-{{ ai_gen_id }} {
    font-family: {{ block.settings.kicker_font.family }}, {{ block.settings.kicker_font.fallback_families }};
    font-style: {{ block.settings.kicker_font.style }};
    font-weight: {{ block.settings.kicker_font_weight }};
    font-size: {{ block.settings.kicker_size }}px;
    line-height: {{ block.settings.kicker_line_height }};
    letter-spacing: {{ block.settings.kicker_letter_spacing }}px;
    color: {{ block.settings.kicker_color }};
    text-transform: {% if block.settings.kicker_uppercase %}uppercase{% else %}none{% endif %};
    margin: 0 0 {{ block.settings.kicker_margin_bottom }}px 0;
  }

  .ai-timeline-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-style: {{ block.settings.heading_font.style }};
    font-weight: {{ block.settings.heading_font_weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
  }

  .ai-timeline-heading-primary-{{ ai_gen_id }} {
    color: {{ block.settings.heading_primary_color }};
  }

  .ai-timeline-heading-secondary-{{ ai_gen_id }} {
    color: {{ block.settings.heading_secondary_color }};
  }

  .ai-timeline-wrap-{{ ai_gen_id }} {
    position: relative;
    overflow-x: {% if block.settings.mobile_behavior == 'scroll' %}auto{% else %}visible{% endif %};
    overflow-y: visible;
    padding-top: {{ block.settings.timeline_top_spacing }}px;
  }

  .ai-timeline-items-{{ ai_gen_id }} {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    column-gap: {{ block.settings.desktop_column_gap }}px;
    min-width: {% if block.settings.mobile_behavior == 'scroll' %}900px{% else %}0{% endif %};
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.dot_size | divided_by: 2 }}px;
    left: 0;
    right: 0;
    height: {{ block.settings.line_thickness }}px;
    background-color: {{ block.settings.line_color }};
    z-index: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding-top: {{ block.settings.dot_spacing_bottom | plus: block.settings.dot_size }}px;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.dot_border_color }};
    z-index: 3;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-family: {{ block.settings.date_font.family }}, {{ block.settings.date_font.fallback_families }};
    font-style: {{ block.settings.date_font.style }};
    font-weight: {{ block.settings.date_font_weight }};
    font-size: {{ block.settings.date_size }}px;
    line-height: {{ block.settings.date_line_height }};
    letter-spacing: {{ block.settings.date_letter_spacing }}px;
    color: {{ block.settings.date_color }};
    text-transform: {% if block.settings.date_uppercase %}uppercase{% else %}none{% endif %};
    margin: 0 0 {{ block.settings.date_margin_bottom }}px 0;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.milestone_title_font.family }}, {{ block.settings.milestone_title_font.fallback_families }};
    font-style: {{ block.settings.milestone_title_font.style }};
    font-weight: {{ block.settings.milestone_title_font_weight }};
    font-size: {{ block.settings.milestone_title_size }}px;
    line-height: {{ block.settings.milestone_title_line_height }};
    letter-spacing: {{ block.settings.milestone_title_letter_spacing }}px;
    color: {{ block.settings.milestone_title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-style: {{ block.settings.description_font.style }};
    font-weight: {{ block.settings.description_font_weight }};
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.description_line_height }};
    letter-spacing: {{ block.settings.description_letter_spacing }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    max-width: {{ block.settings.description_max_width }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
      padding-left: {{ block.settings.mobile_padding_left }}px;
      padding-right: {{ block.settings.mobile_padding_right }}px;
    }

    .ai-timeline-kicker-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_kicker_size }}px;
      line-height: {{ block.settings.mobile_kicker_line_height }};
      letter-spacing: {{ block.settings.mobile_kicker_letter_spacing }}px;
      margin-bottom: {{ block.settings.mobile_kicker_margin_bottom }}px;
    }

    .ai-timeline-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      line-height: {{ block.settings.mobile_heading_line_height }};
      letter-spacing: {{ block.settings.mobile_heading_letter_spacing }}px;
      margin-bottom: {{ block.settings.mobile_heading_margin_bottom }}px;
    }

    {% if block.settings.mobile_behavior == 'stack' %}
      .ai-timeline-items-{{ ai_gen_id }} {
        display: flex;
        flex-direction: column;
        gap: {{ block.settings.mobile_item_gap }}px;
        min-width: 0;
      }

      .ai-timeline-line-{{ ai_gen_id }} {
        top: 0;
        bottom: 0;
        left: {{ block.settings.dot_size | divided_by: 2 }}px;
        right: auto;
        width: {{ block.settings.line_thickness }}px;
        height: auto;
      }

      .ai-timeline-item-{{ ai_gen_id }} {
        padding-top: 0;
        padding-left: {{ block.settings.mobile_stack_text_indent }}px;
      }

      .ai-timeline-dot-{{ ai_gen_id }} {
        left: 0;
        top: 4px;
      }
    {% else %}
      .ai-timeline-items-{{ ai_gen_id }} {
        column-gap: {{ block.settings.mobile_column_gap }}px;
      }
    {% endif %}

    .ai-timeline-date-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_date_size }}px;
      line-height: {{ block.settings.mobile_date_line_height }};
      letter-spacing: {{ block.settings.mobile_date_letter_spacing }}px;
      margin-bottom: {{ block.settings.mobile_date_margin_bottom }}px;
    }

    .ai-timeline-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_milestone_title_size }}px;
      line-height: {{ block.settings.mobile_milestone_title_line_height }};
      letter-spacing: {{ block.settings.mobile_milestone_title_letter_spacing }}px;
      margin-bottom: {{ block.settings.mobile_title_margin_bottom }}px;
    }

    .ai-timeline-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_size }}px;
      line-height: {{ block.settings.mobile_description_line_height }};
      letter-spacing: {{ block.settings.mobile_description_letter_spacing }}px;
      max-width: {{ block.settings.mobile_description_max_width }}px;
    }
  }
{% endstyle %}

<timeline-block-{{ ai_gen_id }}
  class="ai-timeline-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.kicker_text != blank %}
    <p class="ai-timeline-kicker-{{ ai_gen_id }}">
      {{ block.settings.kicker_text }}
    </p>
  {% endif %}

  {% if block.settings.heading_primary != blank or block.settings.heading_secondary != blank %}
    <h2 class="ai-timeline-heading-{{ ai_gen_id }}">
      {% if block.settings.heading_primary != blank %}
        <span class="ai-timeline-heading-primary-{{ ai_gen_id }}">{{ block.settings.heading_primary }}</span>
      {% endif %}
      {% if block.settings.heading_secondary != blank %}
        <span class="ai-timeline-heading-secondary-{{ ai_gen_id }}">{{ block.settings.heading_secondary }}</span>
      {% endif %}
    </h2>
  {% endif %}

  <div class="ai-timeline-wrap-{{ ai_gen_id }}">
    <div class="ai-timeline-items-{{ ai_gen_id }}">
      <div class="ai-timeline-line-{{ ai_gen_id }}"></div>

      {% for i in (1..5) %}
        {% liquid
          assign date_key = 'milestone_' | append: i | append: '_date'
          assign title_key = 'milestone_' | append: i | append: '_title'
          assign description_key = 'milestone_' | append: i | append: '_description'

          assign item_date = block.settings[date_key]
          assign item_title = block.settings[title_key]
          assign item_description = block.settings[description_key]
        %}

        {% if item_date != blank or item_title != blank or item_description != blank %}
          <div class="ai-timeline-item-{{ ai_gen_id }}">
            <span class="ai-timeline-dot-{{ ai_gen_id }}"></span>

            {% if item_date != blank %}
              <p class="ai-timeline-date-{{ ai_gen_id }}">{{ item_date }}</p>
            {% endif %}

            {% if item_title != blank %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ item_title }}</h3>
            {% endif %}

            {% if item_description != blank %}
              <p class="ai-timeline-description-{{ ai_gen_id }}">{{ item_description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</timeline-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TimelineBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    if (!customElements.get('timeline-block-{{ ai_gen_id }}')) {
      customElements.define('timeline-block-{{ ai_gen_id }}', TimelineBlock{{ ai_gen_id }});
    }
  })();
</script>

