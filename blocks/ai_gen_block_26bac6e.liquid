{% doc %}
  @prompt
    Shop the desk section with heading, image hotspot numbers, product cards below, and product popup on hotspot click.
    Mobile: show subheading, image box, center label, hotspots only. Hide main heading and product cards.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shop-desk-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_x }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    background-image:
      linear-gradient({{ block.settings.grid_color }} 1px, transparent 1px),
      linear-gradient(90deg, {{ block.settings.grid_color }} 1px, transparent 1px);
    background-size: {{ block.settings.grid_size }}px {{ block.settings.grid_size }}px;
    color: {{ block.settings.text_color }};
    box-sizing: border-box;
  }

  .ai-shop-desk__inner-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-shop-desk__subheading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheading_bottom_spacing }}px;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: {{ block.settings.subheading_weight }};
    color: {{ block.settings.subheading_color }};
    letter-spacing: {{ block.settings.subheading_letter_spacing }};
    line-height: 1;
    text-align:center;
    text-transform: uppercase;
  }

  .ai-shop-desk__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_bottom_spacing }}px;
    font-family: {{ block.settings.heading_font_family }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    line-height: {{ block.settings.heading_line_height }};
     text-align:center;
  }

  .ai-shop-desk__heading-muted-{{ ai_gen_id }} {
    color: {{ block.settings.heading_muted_color }};
  }

  .ai-shop-desk__image-box-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    border: {{ block.settings.image_border_width }} solid {{ block.settings.border_color }};
    background:
      repeating-linear-gradient(
        -45deg,
        rgba(0, 0, 0, 0.055),
        rgba(0, 0, 0, 0.055) 1px,
        transparent 1px,
        transparent 14px
      );
    overflow: visible;
    box-sizing: border-box;
  }

  .ai-shop-desk__image-box-{{ ai_gen_id }}::before {
    content: "";
    position: absolute;
    top: {{ block.settings.corner_offset }}px;
    left: {{ block.settings.corner_offset }}px;
    width: {{ block.settings.corner_size }}px;
    height: {{ block.settings.corner_size }}px;
    border-top: {{ block.settings.corner_width }} solid {{ block.settings.border_color }};
    border-left: {{ block.settings.corner_width }} solid {{ block.settings.border_color }};
    z-index: 3;
    pointer-events: none;
  }

  .ai-shop-desk__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-shop-desk__center-label-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.center_label_size }}px;
    font-weight: {{ block.settings.center_label_weight }};
    color: {{ block.settings.text_color }};
    letter-spacing: {{ block.settings.center_label_letter_spacing }};
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
    z-index: 2;
  }

  .ai-shop-desk__hotspot-{{ ai_gen_id }} {
    position: absolute;
    top: var(--hotspot-y);
    left: var(--hotspot-x);
    transform: translate(-50%, -50%);
    z-index: 20;
  }

  .ai-shop-desk__hotspot-button-{{ ai_gen_id }} {
    width: {{ block.settings.hotspot_size }}px;
    height: {{ block.settings.hotspot_size }}px;
    border-radius: 999px;
    background: {{ block.settings.hotspot_background }};
    border: {{ block.settings.hotspot_border_width }} solid {{ block.settings.border_color }};
    color: {{ block.settings.hotspot_color }};
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.hotspot_number_size }}px;
    font-weight: {{ block.settings.hotspot_weight }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 1;
    cursor: pointer;
  }

  .ai-shop-desk__popup-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 12px);
    transform: translateX(-50%) translateY(8px);
    width: {{ block.settings.popup_width }}px;
    background: {{ block.settings.card_background }};
    border: {{ block.settings.popup_border_width }} solid {{ block.settings.border_color }};
    padding: {{ block.settings.popup_padding }}px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: 0.2s ease;
    z-index: 30;
    box-sizing: border-box;
  }

  .ai-shop-desk__hotspot-{{ ai_gen_id }}.is-active .ai-shop-desk__popup-{{ ai_gen_id }} {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .ai-shop-desk__popup-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: {{ block.settings.card_title_weight }};
    color: {{ block.settings.text_color }};
    line-height: 1.2;
  }

  .ai-shop-desk__popup-price-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.card_price_size }}px;
    font-weight: {{ block.settings.card_price_weight }};
    color: {{ block.settings.text_color }};
    line-height: 1;
  }

  .ai-shop-desk__popup-link-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.popup_link_size }}px;
    font-weight: {{ block.settings.popup_link_weight }};
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: underline;
  }

  .ai-shop-desk__cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.card_top_spacing }}px;
  }

  .ai-shop-desk__card-{{ ai_gen_id }} {
    min-height: {{ block.settings.card_height }}px;
    border: {{ block.settings.card_border_width }} solid {{ block.settings.card_border_color }};
    background: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding_y }}px {{ block.settings.card_padding_x }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    box-sizing: border-box;
  }

  .ai-shop-desk__card-left-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .ai-shop-desk__card-number-{{ ai_gen_id }} {
    width: {{ block.settings.card_number_size }}px;
    height: {{ block.settings.card_number_size }}px;
    border-radius: 999px;
    border: {{ block.settings.card_number_border_width }} solid {{ block.settings.border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.card_number_font_size }}px;
    font-weight: {{ block.settings.card_number_weight }};
    flex: 0 0 auto;
  }

  .ai-shop-desk__card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: {{ block.settings.card_title_weight }};
    color: {{ block.settings.text_color }};
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ai-shop-desk__card-price-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.card_price_size }}px;
    font-weight: {{ block.settings.card_price_weight }};
    color: {{ block.settings.text_color }};
    line-height: 1;
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .ai-shop-desk__cards-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-shop-desk__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.tablet_heading_size }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-shop-desk-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_x }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-shop-desk__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_subheading_size }}px;
      letter-spacing: {{ block.settings.mobile_subheading_letter_spacing }};
      margin: 0 0 {{ block.settings.mobile_subheading_bottom_spacing }}px;
      white-space: nowrap;
    }

   

    .ai-shop-desk__image-box-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.mobile_image_aspect_ratio }};
      border: {{ block.settings.mobile_image_border_width }} solid {{ block.settings.border_color }};
      overflow: visible;
    }

    .ai-shop-desk__image-box-{{ ai_gen_id }}::before {
      top: {{ block.settings.mobile_corner_offset }}px;
      left: {{ block.settings.mobile_corner_offset }}px;
      width: {{ block.settings.mobile_corner_size }}px;
      height: {{ block.settings.mobile_corner_size }}px;
      border-top: {{ block.settings.mobile_corner_width }} solid {{ block.settings.border_color }};
      border-left: {{ block.settings.mobile_corner_width }} solid {{ block.settings.border_color }};
    }

    .ai-shop-desk__center-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_center_label_size }}px;
      letter-spacing: {{ block.settings.mobile_center_label_letter_spacing }};
      white-space: nowrap;
      text-align: center;
      width: auto;
    }

    .ai-shop-desk__hotspot-button-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_hotspot_size }}px;
      height: {{ block.settings.mobile_hotspot_size }}px;
      font-size: {{ block.settings.mobile_hotspot_number_size }}px;
      border-width: {{ block.settings.mobile_hotspot_border_width }};
      font-weight: {{ block.settings.hotspot_weight }};
    }

    .ai-shop-desk__cards-{{ ai_gen_id }} {
      display: none;
    }

    .ai-shop-desk__popup-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_popup_width }}px;
      padding: {{ block.settings.mobile_popup_padding }}px;
    }

    .ai-shop-desk__popup-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_popup_title_size }}px;
    }

    .ai-shop-desk__popup-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_popup_price_size }}px;
    }
  }
{% endstyle %}

<div class="ai-shop-desk-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-shop-desk__inner-{{ ai_gen_id }}">
    {% if block.settings.subheading != blank %}
      <div class="ai-shop-desk__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank or block.settings.heading_muted != blank %}
      <h2 class="ai-shop-desk__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
        {% if block.settings.heading_muted != blank %}
          <span class="ai-shop-desk__heading-muted-{{ ai_gen_id }}">
            {{ block.settings.heading_muted }}
          </span>
        {% endif %}
      </h2>
    {% endif %}

    <div class="ai-shop-desk__image-box-{{ ai_gen_id }}">
      {% if block.settings.image != blank %}
        <img
          src="{{ block.settings.image | image_url: width: 2200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-shop-desk__image-{{ ai_gen_id }}"
        >
      {% endif %}

      {% if block.settings.center_label != blank %}
        <div class="ai-shop-desk__center-label-{{ ai_gen_id }}">
          {{ block.settings.center_label }}
        </div>
      {% endif %}

      {% for i in (1..4) %}
        {% liquid
          assign show_key = 'hotspot_' | append: i | append: '_enabled'
          assign x_key = 'hotspot_' | append: i | append: '_x'
          assign y_key = 'hotspot_' | append: i | append: '_y'
          assign title_key = 'product_' | append: i | append: '_title'
          assign price_key = 'product_' | append: i | append: '_price'
          assign link_key = 'product_' | append: i | append: '_link'

          assign show_hotspot = block.settings[show_key]
          assign hotspot_x = block.settings[x_key]
          assign hotspot_y = block.settings[y_key]
          assign title = block.settings[title_key]
          assign price = block.settings[price_key]
          assign link = block.settings[link_key]
        %}

        {% if show_hotspot %}
          <div
            class="ai-shop-desk__hotspot-{{ ai_gen_id }}"
            style="--hotspot-x: {{ hotspot_x }}%; --hotspot-y: {{ hotspot_y }}%;"
          >
            <button
              class="ai-shop-desk__hotspot-button-{{ ai_gen_id }}"
              type="button"
              data-hotspot-trigger
              aria-label="Open product {{ i }}"
            >
              {{ i }}
            </button>

            <div class="ai-shop-desk__popup-{{ ai_gen_id }}">
              <p class="ai-shop-desk__popup-title-{{ ai_gen_id }}">
                {{ title }}
              </p>

              <p class="ai-shop-desk__popup-price-{{ ai_gen_id }}">
                {{ price }}
              </p>

              {% if link != blank %}
                <a href="{{ link }}" class="ai-shop-desk__popup-link-{{ ai_gen_id }}">
                  View product
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-shop-desk__cards-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign title_key = 'product_' | append: i | append: '_title'
          assign price_key = 'product_' | append: i | append: '_price'
          assign link_key = 'product_' | append: i | append: '_link'

          assign title = block.settings[title_key]
          assign price = block.settings[price_key]
          assign link = block.settings[link_key]
        %}

        <a
          class="ai-shop-desk__card-{{ ai_gen_id }}"
          href="{% if link != blank %}{{ link }}{% else %}#{% endif %}"
        >
          <span class="ai-shop-desk__card-left-{{ ai_gen_id }}">
            <span class="ai-shop-desk__card-number-{{ ai_gen_id }}">{{ i }}</span>
            <span class="ai-shop-desk__card-title-{{ ai_gen_id }}">{{ title }}</span>
          </span>
         
        </a>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('.ai-shop-desk-{{ ai_gen_id }}');
    if (!section) return;

    const hotspots = section.querySelectorAll('.ai-shop-desk__hotspot-{{ ai_gen_id }}');

    hotspots.forEach(function (hotspot) {
      const button = hotspot.querySelector('[data-hotspot-trigger]');
      if (!button) return;

      button.addEventListener('click', function (event) {
        event.stopPropagation();

        hotspots.forEach(function (item) {
          if (item !== hotspot) {
            item.classList.remove('is-active');
          }
        });

        hotspot.classList.toggle('is-active');
      });
    });

    document.addEventListener('click', function () {
      hotspots.forEach(function (hotspot) {
        hotspot.classList.remove('is-active');
      });
    });
  });
</script>

