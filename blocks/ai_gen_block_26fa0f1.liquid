{% doc %}
  @prompt
    Product FAQ section from product metafields.
    Desktop: two-column FAQ grid with answers always visible.
    Mobile: accordion FAQ rows with right-aligned plus/minus icons.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-faq-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_x }}px {{ block.settings.section_padding_bottom }}px;
    box-sizing: border-box;
  }

  .ai-product-faq__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-product-faq__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font_family }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    line-height: 1;
    text-transform: uppercase;
  }

  .ai-product-faq__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: {{ block.settings.column_gap }}px;
    row-gap: 0;
  }

  .ai-product-faq__item-{{ ai_gen_id }} {
    border-top: {{ block.settings.divider_width }} solid {{ block.settings.divider_color }};
    padding: {{ block.settings.item_padding_top }}px 0 {{ block.settings.item_padding_bottom }}px;
  }

  .ai-product-faq__summary-{{ ai_gen_id }} {
    list-style: none;
    cursor: default;
  }

  .ai-product-faq__summary-{{ ai_gen_id }}::-webkit-details-marker {
    display: none;
  }

  .ai-product-faq__question-row-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .ai-product-faq__question-{{ ai_gen_id }} {
    font-family: {{ block.settings.question_font_family }};
    font-size: {{ block.settings.question_size }}px;
    font-weight: {{ block.settings.question_weight }};
    color: {{ block.settings.question_color }};
    line-height: {{ block.settings.question_line_height }};
    letter-spacing: {{ block.settings.question_letter_spacing }};
    margin: 0 0 {{ block.settings.question_bottom_spacing }}px;
  }

  .ai-product-faq__icon-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-faq__answer-{{ ai_gen_id }} {
    font-family: {{ block.settings.answer_font_family }};
    font-size: {{ block.settings.answer_size }}px;
    font-weight: {{ block.settings.answer_weight }};
    color: {{ block.settings.answer_color }};
    line-height: {{ block.settings.answer_line_height }};
    letter-spacing: {{ block.settings.answer_letter_spacing }};
    margin: 0;
  }

  .ai-product-faq__answer-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-product-faq__empty-{{ ai_gen_id }} {
    border-top: {{ block.settings.divider_width }} solid {{ block.settings.divider_color }};
    padding: 24px 0;
    font-family: {{ block.settings.answer_font_family }};
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-product-faq__item-{{ ai_gen_id }} {
      display: block;
    }

    .ai-product-faq__summary-{{ ai_gen_id }} {
      pointer-events: none;
      cursor: default;
    }

    .ai-product-faq__icon-{{ ai_gen_id }} {
      display: none !important;
    }

    .ai-product-faq__answer-{{ ai_gen_id }} {
      display: block !important;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-faq-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.mobile_section_padding_top }}px {{ block.settings.mobile_section_padding_x }}px {{ block.settings.mobile_section_padding_bottom }}px;
    }

    .ai-product-faq__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      margin-bottom: {{ block.settings.mobile_heading_spacing }}px;
    }

    .ai-product-faq__grid-{{ ai_gen_id }} {
      display: block;
      border-top: {{ block.settings.mobile_divider_width }} solid {{ block.settings.mobile_divider_color }};
    }

    .ai-product-faq__item-{{ ai_gen_id }} {
      border-top: 0;
      border-bottom: {{ block.settings.mobile_divider_width }} solid {{ block.settings.mobile_divider_color }};
      padding: 0;
    }

    .ai-product-faq__summary-{{ ai_gen_id }} {
      cursor: pointer;
      padding: {{ block.settings.mobile_question_padding_y }}px 0;
      pointer-events: auto;
    }

    .ai-product-faq__question-row-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 16px;
      width: 100%;
    }

    .ai-product-faq__question-{{ ai_gen_id }} {
      grid-column: 1;
      font-size: {{ block.settings.mobile_question_size }}px;
      margin: 0;
      line-height: {{ block.settings.mobile_question_line_height }};
    }

    .ai-product-faq__icon-{{ ai_gen_id }} {
      grid-column: 2;
      justify-self: end;
      text-align: right;
      min-width: 20px;
      font-family: {{ block.settings.question_font_family }};
      font-size: {{ block.settings.mobile_icon_size }}px;
      font-weight: {{ block.settings.mobile_icon_weight }};
      color: {{ block.settings.question_color }};
      line-height: 1;
    }

    .ai-product-faq__icon-plus-{{ ai_gen_id }} {
      display: block;
    }

    .ai-product-faq__icon-minus-{{ ai_gen_id }} {
      display: none;
    }

    .ai-product-faq__item-{{ ai_gen_id }}[open] .ai-product-faq__icon-plus-{{ ai_gen_id }} {
      display: none;
    }

    .ai-product-faq__item-{{ ai_gen_id }}[open] .ai-product-faq__icon-minus-{{ ai_gen_id }} {
      display: block;
    }

    .ai-product-faq__answer-{{ ai_gen_id }} {
      display: none;
      font-size: {{ block.settings.mobile_answer_size }}px;
      padding: 0 0 {{ block.settings.mobile_answer_padding_bottom }}px;
    }

    .ai-product-faq__item-{{ ai_gen_id }}[open] .ai-product-faq__answer-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

{% liquid
  assign has_faqs = false
%}

<product-faq-{{ ai_gen_id }} class="ai-product-faq-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-faq__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-product-faq__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </div>
    {% endif %}

    <div class="ai-product-faq__grid-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign question_key = 'faq_question_' | append: i
          assign answer_key = 'faq_answer_' | append: i

          assign question = product.metafields.custom[question_key]
          assign answer = product.metafields.custom[answer_key]
        %}

        {% if question != blank and answer != blank %}
          {% assign has_faqs = true %}

          <details class="ai-product-faq__item-{{ ai_gen_id }}" {% if i == 1 and block.settings.open_first_faq %}open{% endif %}>
            <summary class="ai-product-faq__summary-{{ ai_gen_id }}">
              <div class="ai-product-faq__question-row-{{ ai_gen_id }}">
                <h3 class="ai-product-faq__question-{{ ai_gen_id }}">
                  {{ question }}
                </h3>

                <span class="ai-product-faq__icon-{{ ai_gen_id }} ai-product-faq__icon-plus-{{ ai_gen_id }}">+</span>
                <span class="ai-product-faq__icon-{{ ai_gen_id }} ai-product-faq__icon-minus-{{ ai_gen_id }}">−</span>
              </div>
            </summary>

            <div class="ai-product-faq__answer-{{ ai_gen_id }}">
              {{ answer | metafield_tag }}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>

    {% unless has_faqs %}
      {% if block.settings.show_empty_message %}
        <div class="ai-product-faq__empty-{{ ai_gen_id }}">
          Add FAQ metafields to this product.
        </div>
      {% endif %}
    {% endunless %}
  </div>
</product-faq-{{ ai_gen_id }}>

<script>
  (() => {
    const root = document.querySelector('.ai-product-faq-{{ ai_gen_id }}');
    if (!root) return;

    const items = root.querySelectorAll('.ai-product-faq__item-{{ ai_gen_id }}');
    const openFirstOnMobile = {{ block.settings.open_first_faq | json }};

    function updateFaqMode() {
      const isDesktop = window.matchMedia('(min-width: 750px)').matches;

      items.forEach((item, index) => {
        if (isDesktop) {
          item.setAttribute('open', '');
        } else {
          if (index === 0 && openFirstOnMobile) {
            item.setAttribute('open', '');
          } else {
            item.removeAttribute('open');
          }
        }
      });
    }

    updateFaqMode();

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(updateFaqMode, 150);
    });
  })();
</script>

