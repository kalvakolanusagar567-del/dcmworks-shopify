<div class="custom-button-wrapper-{{ block.id }}">
  {% render 'button', link: block.settings.link %}
</div>

<style>
  .custom-button-wrapper-{{ block.id }} {
    display: block;
  }

  .custom-button-wrapper-{{ block.id }} .button,
  .custom-button-wrapper-{{ block.id }} .button-secondary,
  .custom-button-wrapper-{{ block.id }} a {
    background-color: {{ block.settings.custom_button_bg_color }} !important;
    color: {{ block.settings.custom_button_text_color }} !important;
    border-color: {{ block.settings.custom_button_border_color }} !important;
    border-width: {{ block.settings.custom_button_border_width }}px !important;
    border-style: solid !important;
    font-size: {{ block.settings.custom_button_font_size }}px !important;
    font-weight: {{ block.settings.custom_button_font_weight }} !important;
    border-radius: {{ block.settings.custom_button_radius }}px !important;
    padding: {{ block.settings.custom_button_padding_y }}px {{ block.settings.custom_button_padding_x }}px !important;
    font-family: {{ block.settings.custom_button_font_family }} !important;
    letter-spacing: {{ block.settings.custom_button_letter_spacing }} !important;
    line-height: {{ block.settings.custom_button_line_height }} !important;
    text-transform: {{ block.settings.custom_button_text_transform }} !important;
  }

  .custom-button-wrapper-{{ block.id }} .button:hover,
  .custom-button-wrapper-{{ block.id }} .button-secondary:hover,
  .custom-button-wrapper-{{ block.id }} a:hover {
    background-color: {{ block.settings.custom_button_hover_bg_color }} !important;
    color: {{ block.settings.custom_button_hover_text_color }} !important;
    border-color: {{ block.settings.custom_button_hover_border_color }} !important;
  }

  @media screen and (max-width: 749px) {
    {% unless block.settings.show_button_mobile %}
      .custom-button-wrapper-{{ block.id }} {
        display: none !important;
      }
    {% endunless %}

    .custom-button-wrapper-{{ block.id }} .button,
    .custom-button-wrapper-{{ block.id }} .button-secondary,
    .custom-button-wrapper-{{ block.id }} a {
      font-size: {{ block.settings.custom_button_mobile_font_size }}px !important;
      padding: {{ block.settings.custom_button_mobile_padding_y }}px {{ block.settings.custom_button_mobile_padding_x }}px !important;
      border-radius: {{ block.settings.custom_button_mobile_radius }}px !important;
    }
  }
</style>

{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "t:text_defaults.button_label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "link",
          "label": "t:options.link"
        }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_button_mobile",
      "label": "Show button on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Custom Button Colors"
    },
    {
      "type": "color",
      "id": "custom_button_bg_color",
      "label": "Button background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "custom_button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_button_border_color",
      "label": "Button border color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "custom_button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "custom_button_hover_bg_color",
      "label": "Hover background color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "custom_button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_button_hover_border_color",
      "label": "Hover border color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Custom Button Typography"
    },
    {
      "type": "text",
      "id": "custom_button_font_family",
      "label": "Font family",
      "default": "Inter, Arial, sans-serif"
    },
    {
      "type": "range",
      "id": "custom_button_font_size",
      "label": "Font size desktop",
      "min": 8,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "custom_button_mobile_font_size",
      "label": "Font size mobile",
      "min": 8,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "custom_button_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        },
        {
          "value": "900",
          "label": "Black"
        }
      ],
      "default": "600"
    },
    {
      "type": "text",
      "id": "custom_button_letter_spacing",
      "label": "Letter spacing",
      "default": "0"
    },
    {
      "type": "text",
      "id": "custom_button_line_height",
      "label": "Line height",
      "default": "1.2"
    },
    {
      "type": "select",
      "id": "custom_button_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Custom Button Shape"
    },
    {
      "type": "range",
      "id": "custom_button_radius",
      "label": "Border radius desktop",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "custom_button_mobile_radius",
      "label": "Border radius mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "custom_button_padding_y",
      "label": "Padding top/bottom desktop",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "custom_button_padding_x",
      "label": "Padding left/right desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "custom_button_mobile_padding_y",
      "label": "Padding top/bottom mobile",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "custom_button_mobile_padding_x",
      "label": "Padding left/right mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.button",
      "category": "t:categories.basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}