{% doc %}
  @prompt
    UGC gallery with heading left, follow link right, 6 image boxes in one row.
    Mobile: 3 column grid, option to hide link on mobile.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  #shopify-block-AUzVZdHBuOXV1VERqT__ai_gen_block_834fcd7_6ndzBg {
    width: 100% !important;
  }

  .ai-ugc-gallery-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_x }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    background-image:
      linear-gradient({{ block.settings.grid_color }} 1px, transparent 1px),
      linear-gradient(90deg, {{ block.settings.grid_color }} 1px, transparent 1px);
    background-size: {{ block.settings.grid_size }}px {{ block.settings.grid_size }}px;
    border-top: {{ block.settings.top_border_width }} solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.bottom_border_width }} solid {{ block.settings.border_color }};
    box-sizing: border-box;
  }

  .ai-ugc-inner-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .ai-ugc-header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ugc-heading-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.text_color }};
    letter-spacing: {{ block.settings.letter_spacing }};
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .ai-ugc-link-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.link_size }}px;
    font-weight: {{ block.settings.link_weight }};
    color: {{ block.settings.text_color }};
    letter-spacing: {{ block.settings.letter_spacing }};
    line-height: 1;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
  }

  .ai-ugc-link-{{ ai_gen_id }}:hover {
    opacity: 0.65;
  }

  .ai-ugc-grid-{{ ai_gen_id }} {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-ugc-box-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1.1 / 1;
    border: {{ block.settings.image_border_width }} solid {{ block.settings.border_color }};
    background:
      repeating-linear-gradient(
        -45deg,
        rgba(0, 0, 0, 0.055),
        rgba(0, 0, 0, 0.055) 1px,
        transparent 1px,
        transparent 14px
      );
    overflow: hidden;
    box-sizing: border-box;
  }

  .ai-ugc-box-{{ ai_gen_id }}::before {
    content: "";
    position: absolute;
    top: 10px;
    left: 10px;
    width: 14px;
    height: 14px;
    border-top: {{ block.settings.corner_width }} solid {{ block.settings.border_color }};
    border-left: {{ block.settings.corner_width }} solid {{ block.settings.border_color }};
    z-index: 2;
    pointer-events: none;
  }

  .ai-ugc-img-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-ugc-placeholder-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.placeholder_size }}px;
    font-weight: {{ block.settings.placeholder_weight }};
    color: {{ block.settings.text_color }};
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    .ai-ugc-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ugc-gallery-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_x }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-ugc-header-{{ ai_gen_id }} {
      align-items: center;
      gap: 12px;
      flex-direction: row;
      justify-content: space-between;
      margin-bottom: {{ block.settings.mobile_header_spacing }}px;
    }

    .ai-ugc-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      white-space: nowrap;
    }

    .ai-ugc-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_link_size }}px;
    }

    {% unless block.settings.show_link_mobile %}
      .ai-ugc-link-{{ ai_gen_id }} {
        display: none !important;
      }
    {% endunless %}

    .ai-ugc-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: {{ block.settings.mobile_image_gap }}px;
    }

    .ai-ugc-box-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.mobile_image_aspect_ratio }};
    }

    .ai-ugc-box-{{ ai_gen_id }}::before {
      top: {{ block.settings.mobile_corner_offset }}px;
      left: {{ block.settings.mobile_corner_offset }}px;
      width: {{ block.settings.mobile_corner_size }}px;
      height: {{ block.settings.mobile_corner_size }}px;
    }

    .ai-ugc-placeholder-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_placeholder_size }}px;
      letter-spacing: {{ block.settings.mobile_placeholder_letter_spacing }};
    }
  }
{% endstyle %}

<div class="ai-ugc-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ugc-inner-{{ ai_gen_id }}">
    <div class="ai-ugc-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-ugc-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.link_text != blank %}
        <a href="{{ block.settings.link_url }}" class="ai-ugc-link-{{ ai_gen_id }}">
          {{ block.settings.link_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-ugc-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}

        <div class="ai-ugc-box-{{ ai_gen_id }}">
          {% if image != blank %}
            <img
              src="{{ image | image_url: width: 700 }}"
              alt="{{ image.alt | escape }}"
              width="{{ image.width }}"
              height="{{ image.height }}"
              loading="lazy"
              class="ai-ugc-img-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-ugc-placeholder-{{ ai_gen_id }}">
              UGC #{{ i }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

