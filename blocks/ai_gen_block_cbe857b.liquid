{% doc %}
  @prompt
    Reviews / testimonials block.
    Desktop: 3 column testimonial cards.
    Mobile: compact reviews list with header, dividers, and show more reviews button.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0px;
    background-color: {{ block.settings.background_color }};
    font-family: {{ block.settings.body_font_family }};
    box-sizing: border-box;
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.desktop_side_padding }}px;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_bottom_spacing }}px;
  }

  .ai-testimonials-heading-box-{{ ai_gen_id }} {
    display: inline-block;
    border: {{ block.settings.heading_border_width }}px solid {{ block.settings.heading_border_color }};
    border-radius: {{ block.settings.heading_border_radius }}px;
    padding: {{ block.settings.heading_padding_y }}px {{ block.settings.heading_padding_x }}px;
    background-color: {{ block.settings.heading_background }};
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font_family }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    text-transform: {{ block.settings.heading_text_transform }};
  }

  .ai-testimonials-mobile-top-{{ ai_gen_id }},
  .ai-testimonials-mobile-footer-{{ ai_gen_id }} {
    display: none;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_content_gap }}px;
    min-height: {{ block.settings.card_min_height }}px;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    color: {{ block.settings.star_color }};
    font-family: {{ block.settings.star_font_family }};
    font-size: {{ block.settings.star_size }}px;
    font-weight: {{ block.settings.star_font_weight }};
    line-height: {{ block.settings.star_line_height }};
    letter-spacing: {{ block.settings.star_letter_spacing }};
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-family: {{ block.settings.quote_font_family }};
    font-size: {{ block.settings.quote_size }}px;
    color: {{ block.settings.quote_color }};
    line-height: {{ block.settings.quote_line_height }};
    letter-spacing: {{ block.settings.quote_letter_spacing }};
    font-weight: {{ block.settings.quote_font_weight }};
    margin: 0;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    font-family: {{ block.settings.author_font_family }};
    font-size: {{ block.settings.author_size }}px;
    color: {{ block.settings.author_color }};
    font-weight: {{ block.settings.author_font_weight }};
    line-height: {{ block.settings.author_line_height }};
    letter-spacing: {{ block.settings.author_letter_spacing }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.mobile_section_padding_top }}px 0 {{ block.settings.mobile_section_padding_bottom }}px;
    }

    .ai-testimonials-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_side_padding }}px;
    }

    .ai-testimonials-header-{{ ai_gen_id }} {
      display: none;
    }

    .ai-testimonials-mobile-top-{{ ai_gen_id }} {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding-bottom: {{ block.settings.mobile_header_padding_bottom }}px;
      border-bottom: {{ block.settings.mobile_divider_width }} solid {{ block.settings.mobile_divider_color }};
      margin-bottom: 0;
    }

    .ai-testimonials-mobile-title-{{ ai_gen_id }},
    .ai-testimonials-mobile-see-all-{{ ai_gen_id }} {
      font-family: {{ block.settings.mobile_nav_font_family }};
      font-size: {{ block.settings.mobile_nav_size }}px;
      font-weight: {{ block.settings.mobile_nav_weight }};
      color: {{ block.settings.mobile_nav_color }};
      letter-spacing: {{ block.settings.mobile_nav_letter_spacing }};
      line-height: 1;
      text-transform: uppercase;
      text-decoration: none;
    }

    .ai-testimonials-mobile-star-{{ ai_gen_id }} {
      color: {{ block.settings.star_color }};
      letter-spacing: 0;
    }

    .ai-testimonials-grid-{{ ai_gen_id }} {
      display: block;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      border: 0;
      border-radius: 0;
      border-bottom: {{ block.settings.mobile_divider_width }} solid {{ block.settings.mobile_divider_color }};
      background: transparent;
      padding: {{ block.settings.mobile_card_padding_y }}px 0;
      min-height: 0;
      gap: {{ block.settings.mobile_content_gap }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }}.is-hidden-mobile {
      max-height: 0;
      opacity: 0;
      padding-top: 0;
      padding-bottom: 0;
      border-bottom-width: 0;
      overflow: hidden;
      transform: translateY(-6px);
      pointer-events: none;
      transition:
        max-height 0.38s ease,
        opacity 0.26s ease,
        padding 0.32s ease,
        transform 0.32s ease,
        border-width 0.32s ease;
    }

    .ai-testimonial-card-{{ ai_gen_id }}.is-hidden-mobile.is-visible-mobile {
      max-height: 420px;
      opacity: 1;
      padding: {{ block.settings.mobile_card_padding_y }}px 0;
      border-bottom: {{ block.settings.mobile_divider_width }} solid {{ block.settings.mobile_divider_color }};
      transform: translateY(0);
      pointer-events: auto;
    }

    .ai-testimonials-mobile-see-all-{{ ai_gen_id }} {
      appearance: none;
      border: 0;
      background: transparent;
      padding: 0;
      cursor: pointer;
    }

    .ai-testimonials-mobile-see-all-{{ ai_gen_id }}.is-hidden {
      display: none;
    }

    .ai-testimonial-stars-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_star_size }}px;
      gap: {{ block.settings.mobile_star_gap }}px;
      letter-spacing: {{ block.settings.mobile_star_letter_spacing }};
    }

    .ai-testimonial-quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_quote_size }}px;
      line-height: {{ block.settings.mobile_quote_line_height }};
      letter-spacing: {{ block.settings.mobile_quote_letter_spacing }};
    }

    .ai-testimonial-author-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_author_size }}px;
      line-height: {{ block.settings.mobile_author_line_height }};
      letter-spacing: {{ block.settings.mobile_author_letter_spacing }};
      color: {{ block.settings.mobile_author_color }};
    }

    .ai-testimonials-mobile-footer-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      align-items: center;
      padding-top: {{ block.settings.mobile_footer_padding_top }}px;
    }
  }
{% endstyle %}

<testimonials-block-{{ ai_gen_id }} class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-testimonials-header-{{ ai_gen_id }}">
        <div class="ai-testimonials-heading-box-{{ ai_gen_id }}">
          <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        </div>
      </div>
    {% endif %}

    <div class="ai-testimonials-mobile-top-{{ ai_gen_id }}">
      <div class="ai-testimonials-mobile-title-{{ ai_gen_id }}">
        {{ block.settings.mobile_header_text }}
        <span>·</span>
        <span class="ai-testimonials-mobile-star-{{ ai_gen_id }}">★</span>
        <span>{{ block.settings.mobile_rating_text }}</span>
      </div>

    </div>

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign author_key = 'testimonial_' | append: i | append: '_author'
          assign rating_key = 'testimonial_' | append: i | append: '_rating'

          assign quote = block.settings[quote_key]
          assign author = block.settings[author_key]
          assign rating = block.settings[rating_key]
        %}

        <div class="ai-testimonial-card-{{ ai_gen_id }}{% if forloop.index > 2 %} is-hidden-mobile{% endif %}" data-review-card>
          <div class="ai-testimonial-stars-{{ ai_gen_id }}">
            {% for star in (1..rating) %}
              <span>★</span>
            {% endfor %}
          </div>

          {% if quote != blank %}
            <p class="ai-testimonial-quote-{{ ai_gen_id }}">
              "{{ quote }}"
            </p>
          {% endif %}

          {% if author != blank %}
            <p class="ai-testimonial-author-{{ ai_gen_id }}">
              {{ author }}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if block.settings.see_all_text != blank %}
      <div class="ai-testimonials-mobile-footer-{{ ai_gen_id }}">
        <button type="button" class="ai-testimonials-mobile-see-all-{{ ai_gen_id }}" data-show-more-reviews>
          {{ block.settings.see_all_text }}
        </button>
      </div>
    {% endif %}
  </div>
</testimonials-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsBlock{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        this.showMoreButton = this.querySelector('[data-show-more-reviews]');
        this.cards = Array.from(this.querySelectorAll('[data-review-card]'));
        this.visibleCount = 2;
        this.maxVisible = Math.min(10, this.cards.length);

        if (!this.showMoreButton) return;

        this.showMoreButton.addEventListener('click', () => {
          this.visibleCount = Math.min(this.visibleCount + 2, this.maxVisible);
          this.updateVisibleReviews();
        });

        this.updateVisibleReviews();
      }

      updateVisibleReviews() {
        this.cards.forEach((card, index) => {
          if (index < this.visibleCount) {
            card.classList.add('is-visible-mobile');
          }
        });

        if (this.showMoreButton && this.visibleCount >= this.maxVisible) {
          this.showMoreButton.classList.add('is-hidden');
        }
      }
    }

    customElements.define('testimonials-block-{{ ai_gen_id }}', TestimonialsBlock{{ ai_gen_id }});
  })();
</script>

