{% doc %}
  @prompt
    Accessories section from selected collection.
    Desktop: 3 horizontal bordered cards.
    Mobile: stacked cards.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign selected_collection = block.settings.accessories_collection
  assign product_count = 0

  if selected_collection != blank
    assign product_count = selected_collection.products_count
  endif

  assign shown_count = product_count
  if shown_count > block.settings.products_limit
    assign shown_count = block.settings.products_limit
  endif
%}

{% style %}
  .ai-accessories-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-accessories-{{ ai_gen_id }} *,
  .ai-accessories-{{ ai_gen_id }} *::before,
  .ai-accessories-{{ ai_gen_id }} *::after {
    box-sizing: border-box;
  }

  .ai-accessories__header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: {{ block.settings.header_bottom_gap }}px;
  }

  .ai-accessories__heading-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .ai-accessories__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: uppercase;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
  }

  .ai-accessories__count-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    color: {{ block.settings.accent_color }};
    line-height: 1.2;
  }

  .ai-accessories__viewall-{{ ai_gen_id }} {
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.link_size }}px;
    letter-spacing: {{ block.settings.link_letter_spacing }}px;
    text-transform: lowercase;
    white-space: nowrap;
  }

  .ai-accessories__viewall-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accent_color }};
  }

  .ai-accessories__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-accessories__card-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    background: transparent;
    padding: {{ block.settings.card_padding }}px;
    min-width: 0;
  }

  .ai-accessories__card-inner-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.image_size }}px minmax(0, 1fr);
    gap: {{ block.settings.card_inner_gap }}px;
    align-items: start;
  }

  .ai-accessories__media-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border: 1px solid {{ block.settings.image_border_color }};
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    background: transparent;
  }

  .ai-accessories__media-{{ ai_gen_id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(135deg, transparent 0 48%, {{ block.settings.grid_line_color }} 48%, {{ block.settings.grid_line_color }} 52%, transparent 52%);
    background-size: 18px 18px;
    opacity: 0.35;
    pointer-events: none;
  }

  .ai-accessories__media-corner-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    left: 8px;
    width: 12px;
    height: 12px;
    border-top: 1px solid {{ block.settings.text_color }};
    border-left: 1px solid {{ block.settings.text_color }};
    z-index: 2;
  }

  .ai-accessories__media-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 1;
  }

  .ai-accessories__placeholder-code-{{ ai_gen_id }} {
    position: absolute;
    right: 10px;
    bottom: 10px;
    font-size: {{ block.settings.placeholder_code_size }}px;
    letter-spacing: {{ block.settings.placeholder_code_spacing }}px;
    color: {{ block.settings.muted_color }};
    text-transform: uppercase;
    z-index: 2;
  }

  .ai-accessories__content-{{ ai_gen_id }} {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
    height: 100%;
  }

  .ai-accessories__type-{{ ai_gen_id }} {
    display: block;
    margin: 0 0 4px;
    font-size: {{ block.settings.meta_size }}px;
    letter-spacing: {{ block.settings.meta_letter_spacing }}px;
    color: {{ block.settings.muted_color }};
    text-transform: uppercase;
    line-height: 1.1;
  }

  .ai-accessories__name-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.product_name_size }}px;
    font-weight: {{ block.settings.product_name_weight }};
    line-height: 1.25;
    color: {{ block.settings.text_color }};
    word-break: break-word;
  }

  .ai-accessories__footer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
  }

  .ai-accessories__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.text_color }};
    line-height: 1;
    white-space: nowrap;
  }

  .ai-accessories__form-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-accessories__button-{{ ai_gen_id }} {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    color: {{ block.settings.accent_color }};
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    line-height: 1;
  }

  .ai-accessories__button-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-accessories__empty-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    padding: 18px;
    font-size: 13px;
    color: {{ block.settings.muted_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-accessories__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_grid_gap }}px;
    }

    .ai-accessories__header-{{ ai_gen_id }} {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }

    .ai-accessories__card-inner-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.mobile_image_size }}px minmax(0, 1fr);
      gap: 14px;
    }

    .ai-accessories__media-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_image_size }}px;
      height: {{ block.settings.mobile_image_size }}px;
    }

    .ai-accessories__title-{{ ai_gen_id }},
    .ai-accessories__count-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_title_size }}px;
    }

    .ai-accessories__name-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_product_name_size }}px;
    }
  }
{% endstyle %}

<section class="ai-accessories-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-accessories__header-{{ ai_gen_id }}">
    <div class="ai-accessories__heading-{{ ai_gen_id }}">
      <h2 class="ai-accessories__title-{{ ai_gen_id }}">
        {{ block.settings.section_title }}
      </h2>

      <span class="ai-accessories__count-{{ ai_gen_id }}">
        · {{ shown_count }}
      </span>
    </div>

    {% if selected_collection != blank %}
      <a href="{{ selected_collection.url }}" class="ai-accessories__viewall-{{ ai_gen_id }}">
        {{ block.settings.view_all_text }}
      </a>
    {% elsif block.settings.view_all_link != blank %}
      <a href="{{ block.settings.view_all_link }}" class="ai-accessories__viewall-{{ ai_gen_id }}">
        {{ block.settings.view_all_text }}
      </a>
    {% endif %}
  </div>

  {% if selected_collection != blank and selected_collection.products_count > 0 %}
    <div class="ai-accessories__grid-{{ ai_gen_id }}">
      {% for product in selected_collection.products limit: block.settings.products_limit %}
        {% liquid
          assign product_code = block.settings.default_product_code

          if forloop.index == 1 and block.settings.product_1_code != blank
            assign product_code = block.settings.product_1_code
          elsif forloop.index == 2 and block.settings.product_2_code != blank
            assign product_code = block.settings.product_2_code
          elsif forloop.index == 3 and block.settings.product_3_code != blank
            assign product_code = block.settings.product_3_code
          endif
        %}

        <article class="ai-accessories__card-{{ ai_gen_id }}">
          <div class="ai-accessories__card-inner-{{ ai_gen_id }}">
            <div class="ai-accessories__media-{{ ai_gen_id }}">
              <span class="ai-accessories__media-corner-{{ ai_gen_id }}"></span>

              {% if product.featured_image != blank %}
                {{
                  product.featured_image
                  | image_url: width: 240
                  | image_tag:
                    loading: 'lazy',
                    widths: '120, 180, 240',
                    alt: product.title
                }}
              {% endif %}

              <span class="ai-accessories__placeholder-code-{{ ai_gen_id }}">
                {{ product_code }}
              </span>
            </div>

            <div class="ai-accessories__content-{{ ai_gen_id }}">
              <div>
                <span class="ai-accessories__type-{{ ai_gen_id }}">
                  {{ block.settings.product_type_label }}
                </span>

                <h3 class="ai-accessories__name-{{ ai_gen_id }}">
                  {{ product.title }}
                </h3>
              </div>

              <div class="ai-accessories__footer-{{ ai_gen_id }}">
                <span class="ai-accessories__price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </span>

                <form method="post" action="/cart/add" class="ai-accessories__form-{{ ai_gen_id }}">
                  <input
                    type="hidden"
                    name="id"
                    value="{{ product.selected_or_first_available_variant.id }}"
                  >
                  <button type="submit" class="ai-accessories__button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </button>
                </form>
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-accessories__empty-{{ ai_gen_id }}">
      Select a collection/category in the theme editor to show products here.
    </div>
  {% endif %}
</section>

{% schema %}
