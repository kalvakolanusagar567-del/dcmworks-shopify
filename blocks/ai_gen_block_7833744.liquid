{% doc %}
  @prompt
    END · SERIES 01
    Series 02 drops · Q3 · 2026
    Notify me →
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  {{ block.settings.kicker_font | font_face }}
  {{ block.settings.heading_font | font_face }}
  {{ block.settings.button_font | font_face }}

  .ai-series-end-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_sides }}px {{ block.settings.padding_bottom }}px;
    text-align: center;
    position: relative;
    box-sizing: border-box;
    overflow: hidden;
    margin-top: 0;
  }

  .ai-series-end-{{ ai_gen_id }} *,
  .ai-series-end-{{ ai_gen_id }} *::before,
  .ai-series-end-{{ ai_gen_id }} *::after {
    box-sizing: border-box;
  }

  .ai-series-end__inner-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin: 0 auto;
  }

  .ai-series-end__kicker-{{ ai_gen_id }},
  .ai-series-end__heading-{{ ai_gen_id }},
  .ai-series-end__button-{{ ai_gen_id }} {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-series-end__kicker-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.kicker_bottom_gap }}px;
    font-family: {{ block.settings.kicker_font.family }}, {{ block.settings.kicker_font.fallback_families }};
    font-style: {{ block.settings.kicker_font.style }};
    font-weight: {{ block.settings.kicker_weight }};
    font-size: {{ block.settings.kicker_size }}px;
    line-height: 1.2;
    letter-spacing: {{ block.settings.kicker_letter_spacing }}px;
    color: {{ block.settings.kicker_color }};
    text-transform: uppercase;
  }

  .ai-series-end__heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_bottom_gap }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-style: {{ block.settings.heading_font.style }};
    font-weight: {{ block.settings.heading_weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-series-end__accent-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
  }

  .ai-series-end__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-width: {{ block.settings.button_min_width }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-style: {{ block.settings.button_font.style }};
    font-weight: {{ block.settings.button_weight }};
    font-size: {{ block.settings.button_size }}px;
    line-height: 1;
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .ai-series-end__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-series-end__arrow-{{ ai_gen_id }} {
    display: inline-block;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .ai-series-end__button-{{ ai_gen_id }}:hover .ai-series-end__arrow-{{ ai_gen_id }} {
    transform: translateX(3px);
  }

  @media screen and (max-width: 749px) {
    .ai-series-end-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_sides }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-series-end__inner-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      margin: 0 auto;
    }

    .ai-series-end__kicker-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_kicker_size }}px;
      letter-spacing: {{ block.settings.mobile_kicker_letter_spacing }}px;
      margin-bottom: {{ block.settings.mobile_kicker_bottom_gap }}px;
    }

    .ai-series-end__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      line-height: {{ block.settings.mobile_heading_line_height }};
      letter-spacing: {{ block.settings.mobile_heading_letter_spacing }}px;
      margin-bottom: {{ block.settings.mobile_heading_bottom_gap }}px;
    }

    .ai-series-end__button-{{ ai_gen_id }} {
      min-width: {{ block.settings.mobile_button_min_width }}px;
      padding: {{ block.settings.mobile_button_padding_vertical }}px {{ block.settings.mobile_button_padding_horizontal }}px;
      font-size: {{ block.settings.mobile_button_size }}px;
      letter-spacing: {{ block.settings.mobile_button_letter_spacing }}px;
    }
  }
{% endstyle %}

<section class="ai-series-end-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-series-end__inner-{{ ai_gen_id }}">
    {% if block.settings.kicker != blank %}
      <p class="ai-series-end__kicker-{{ ai_gen_id }}">
        {{ block.settings.kicker }}
      </p>
    {% endif %}

    {% if block.settings.heading_before != blank or block.settings.heading_accent != blank %}
      <h2 class="ai-series-end__heading-{{ ai_gen_id }}">
        {{ block.settings.heading_before }}
        {% if block.settings.heading_accent != blank %}
          <span class="ai-series-end__accent-{{ ai_gen_id }}">
            {{ block.settings.heading_accent }}
          </span>
        {% endif %}
      </h2>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{% if block.settings.button_link != blank %}{{ block.settings.button_link }}{% else %}#{% endif %}"
        class="ai-series-end__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
        <span class="ai-series-end__arrow-{{ ai_gen_id }}">→</span>
      </a>
    {% endif %}
  </div>
</section>

