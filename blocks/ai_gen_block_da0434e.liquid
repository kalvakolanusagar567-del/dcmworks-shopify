{% doc %}
  @prompt
    AS SEEN IN heading and logo text items.
    Desktop: heading and 5 logo texts in one row.
    Mobile: heading centered above 3 logo texts in one row with dots.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-as-seen-in-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_x }}px {{ block.settings.section_padding_bottom }}px;
    display: block;
    background-color: {{ block.settings.background_color }};
    border-top: {{ block.settings.top_border_width }} solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.bottom_border_width }} solid {{ block.settings.border_color }};
    box-sizing: border-box;
  }

  .ai-as-seen-in__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.heading_column_width }}fr repeat(5, 1fr);
    align-items: center;
    gap: {{ block.settings.gap_between_columns }}px;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-as-seen-in__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_font_size }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    line-height: {{ block.settings.heading_line_height }};
    text-transform: {{ block.settings.heading_text_transform }};
    white-space: nowrap;
  }

  .ai-as-seen-in__logo-item-{{ ai_gen_id }} {
    margin: 0;
    text-align: {{ block.settings.logo_alignment }};
    font-size: {{ block.settings.logo_font_size }}px;
    font-family: {{ block.settings.logo_font.family }}, {{ block.settings.logo_font.fallback_families }};
    font-weight: {{ block.settings.logo_font.weight }};
    color: {{ block.settings.logo_color }};
    letter-spacing: {{ block.settings.logo_letter_spacing }};
    line-height: {{ block.settings.logo_line_height }};
    text-transform: {{ block.settings.logo_text_transform }};
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .ai-as-seen-in__row-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      row-gap: {{ block.settings.tablet_row_gap }}px;
    }

    .ai-as-seen-in__heading-{{ ai_gen_id }} {
      grid-column: 1 / -1;
      text-align: center;
    }
  }

  @media screen and (max-width: 749px) {
  .ai-as-seen-in-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_x }}px {{ block.settings.mobile_padding_bottom }}px;
    overflow: hidden;
  }

  .ai-as-seen-in__row-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    text-align: center;
  }

  .ai-as-seen-in__heading-{{ ai_gen_id }} {
    width: 100%;
    flex: 0 0 100%;
    text-align: center;
    font-size: {{ block.settings.mobile_heading_font_size }}px;
    letter-spacing: {{ block.settings.mobile_heading_letter_spacing }};
    margin: 0 0 {{ block.settings.mobile_heading_bottom_spacing }}px;
    line-height: {{ block.settings.heading_line_height }};
  }

  .ai-as-seen-in__logo-item-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    font-size: {{ block.settings.mobile_logo_font_size }}px;
    letter-spacing: {{ block.settings.mobile_logo_letter_spacing }};
    line-height: {{ block.settings.logo_line_height }};
    margin: 0;
    white-space: nowrap;
  }

  .ai-as-seen-in__logo-item-{{ ai_gen_id }}--1,
  .ai-as-seen-in__logo-item-{{ ai_gen_id }}--3,
  .ai-as-seen-in__logo-item-{{ ai_gen_id }}--4 {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-as-seen-in__logo-item-{{ ai_gen_id }}--1::after,
  .ai-as-seen-in__logo-item-{{ ai_gen_id }}--3::after {
    content: "·";
    display: inline-block;
    margin: 0 {{ block.settings.mobile_dot_spacing }}px;
    letter-spacing: 0;
    font-weight: 700;
  }

  .ai-as-seen-in__logo-item-{{ ai_gen_id }}--4::after {
    display: none;
  }
}
{% endstyle %}

<div class="ai-as-seen-in-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-in__row-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <p class="ai-as-seen-in__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </p>
    {% endif %}

    {% if block.settings.logo_1 != blank %}
      <p class="ai-as-seen-in__logo-item-{{ ai_gen_id }} ai-as-seen-in__logo-item-{{ ai_gen_id }}--1">
        {{ block.settings.logo_1 }}
      </p>
    {% endif %}

    {% if block.settings.logo_2 != blank %}
      <p class="ai-as-seen-in__logo-item-{{ ai_gen_id }} ai-as-seen-in__logo-item-{{ ai_gen_id }}--2">
        {{ block.settings.logo_2 }}
      </p>
    {% endif %}

    {% if block.settings.logo_3 != blank %}
      <p class="ai-as-seen-in__logo-item-{{ ai_gen_id }} ai-as-seen-in__logo-item-{{ ai_gen_id }}--3">
        {{ block.settings.logo_3 }}
      </p>
    {% endif %}

    {% if block.settings.logo_4 != blank %}
      <p class="ai-as-seen-in__logo-item-{{ ai_gen_id }} ai-as-seen-in__logo-item-{{ ai_gen_id }}--4">
        {{ block.settings.logo_4 }}
      </p>
    {% endif %}

    {% if block.settings.logo_5 != blank %}
      <p class="ai-as-seen-in__logo-item-{{ ai_gen_id }} ai-as-seen-in__logo-item-{{ ai_gen_id }}--5">
        {{ block.settings.logo_5 }}
      </p>
    {% endif %}
  </div>
</div>

