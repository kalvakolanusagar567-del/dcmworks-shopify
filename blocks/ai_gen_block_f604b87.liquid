{% doc %}
  @prompt
    Aligned uppercase stat list with 5 rows. Same spacing for label and text, fixed columns, clean single-line layout, fully customizable typography.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  {{ block.settings.label_font | font_face }}
  {{ block.settings.text_font | font_face }}

  .ai-stat-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow-x: auto;
  }

  .ai-stat-list__items-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.label_column_width }}px 1fr;
    column-gap: {{ block.settings.desktop_column_gap }}px;
    row-gap: {{ block.settings.desktop_row_gap }}px;
    margin: 0;
    padding: 0;
    list-style: none;
    min-width: max-content;
  }

  .ai-stat-list__label-{{ ai_gen_id }} {
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-style: {{ block.settings.label_font.style }};
    font-weight: {{ block.settings.label_font_weight }};
    font-size: {{ block.settings.desktop_label_size }}px;
    line-height: {{ block.settings.desktop_line_height }};
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    white-space: nowrap;
    margin: 0;
  }

  .ai-stat-list__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-style: {{ block.settings.text_font.style }};
    font-weight: {{ block.settings.text_font_weight }};
    font-size: {{ block.settings.desktop_text_size }}px;
    line-height: {{ block.settings.desktop_line_height }};
    letter-spacing: {{ block.settings.text_letter_spacing }}px;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    white-space: nowrap;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-stat-list-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
    }

    .ai-stat-list__items-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.mobile_label_column_width }}px 1fr;
      column-gap: {{ block.settings.mobile_column_gap }}px;
      row-gap: {{ block.settings.mobile_row_gap }}px;
    }

    .ai-stat-list__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_label_size }}px;
      line-height: {{ block.settings.mobile_line_height }};
      letter-spacing: {{ block.settings.mobile_label_letter_spacing }}px;
      white-space: nowrap;
    }

    .ai-stat-list__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
      line-height: {{ block.settings.mobile_line_height }};
      letter-spacing: {{ block.settings.mobile_text_letter_spacing }}px;
      white-space: nowrap;
    }
  }
{% endstyle %}

<stat-list-{{ ai_gen_id }}
  class="ai-stat-list-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-stat-list__items-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign label_key = 'item_' | append: i | append: '_label'
        assign text_key = 'item_' | append: i | append: '_text'
        assign item_label = block.settings[label_key]
        assign item_text = block.settings[text_key]
      %}

      {% if item_label != blank or item_text != blank %}
        <p class="ai-stat-list__label-{{ ai_gen_id }}">{{ item_label }}</p>
        <p class="ai-stat-list__text-{{ ai_gen_id }}">{{ item_text }}</p>
      {% endif %}
    {% endfor %}
  </div>
</stat-list-{{ ai_gen_id }}>

<script>
  (function() {
    class StatList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    if (!customElements.get('stat-list-{{ ai_gen_id }}')) {
      customElements.define('stat-list-{{ ai_gen_id }}', StatList{{ ai_gen_id }});
    }
  })();
</script>

