{% doc %}
  @prompt
    Premium DriftPad product showcase with product media slider, video first, product images after, equal media size, desktop split layout, mobile product layout, variants, quantity, add to cart, dynamic checkout, full typography controls.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign product = block.settings.product %}

{% style %}
  {{ block.settings.heading_font | font_face }}
  {{ block.settings.body_font | font_face }}

  .dp-feature-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.section_bg }};
    padding: {{ block.settings.desktop_padding_top }}px {{ block.settings.desktop_side_padding }}px {{ block.settings.desktop_padding_bottom }}px;
    color: {{ block.settings.text_color }};
  }

  .dp-feature__shell-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.inner_padding }}px;
    background: {{ block.settings.card_bg }};
    overflow: hidden;
  }

  .dp-feature__top-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_gap }}px;
  }

  .dp-feature__kicker-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.kicker_size }}px;
    font-weight: {{ block.settings.kicker_weight }};
    letter-spacing: {{ block.settings.kicker_spacing }}px;
    color: {{ block.settings.accent_color }};
    text-transform: uppercase;
    margin: 0 0 8px;
    line-height: {{ block.settings.kicker_line_height }};
  }

  .dp-feature__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_spacing }}px;
    margin: 0 0 8px;
    color: {{ block.settings.heading_color }};
  }

  .dp-feature__subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: {{ block.settings.subheading_weight }};
    letter-spacing: {{ block.settings.subheading_spacing }}px;
    line-height: {{ block.settings.subheading_line_height }};
    color: {{ block.settings.muted_color }};
    margin: 0;
  }

  .dp-feature__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(360px, 0.95fr);
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .dp-feature__media-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.image_radius }}px;
    overflow: hidden;
    background: #111111;
    aspect-ratio: {{ block.settings.desktop_media_aspect }};
    height: auto;
    min-height: 0;
  }

  .dp-feature__media-track-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .dp-feature__media-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  .dp-feature__media-slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    min-width: 100%;
    height: 100%;
    scroll-snap-align: start;
    position: relative;
    background: #111111;
  }

  .dp-feature__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 0;
    display: block;
    object-fit: cover;
  }

  .dp-feature__video-{{ ai_gen_id }},
  .dp-feature__external-video-{{ ai_gen_id }},
  .dp-feature__media-slide-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    min-height: 0;
    display: block;
    object-fit: cover;
  }

  .dp-feature__media-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    z-index: 4;
    transform: translateY(-50%);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.65);
    background: rgba(0,0,0,.45);
    color: #ffffff;
    font-size: 30px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dp-feature__media-arrow--prev-{{ ai_gen_id }} {
    left: 14px;
  }

  .dp-feature__media-arrow--next-{{ ai_gen_id }} {
    right: 14px;
  }

  .dp-feature__counter-{{ ai_gen_id }} {
    position: absolute;
    left: 20px;
    bottom: 20px;
    background: rgba(0,0,0,.75);
    color: #ffffff;
    border-radius: 999px;
    padding: 9px 13px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.counter_size }}px;
    font-weight: {{ block.settings.counter_weight }};
    letter-spacing: {{ block.settings.counter_spacing }}px;
    line-height: 1;
    z-index: 5;
  }

  .dp-feature__card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: {{ block.settings.card_bg }};
  }

  .dp-feature__product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: {{ block.settings.product_title_weight }};
    line-height: {{ block.settings.product_title_line_height }};
    letter-spacing: {{ block.settings.product_title_spacing }}px;
    margin: 0 0 10px;
    color: {{ block.settings.heading_color }};
  }

  .dp-feature__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.rating_size }}px;
    font-weight: {{ block.settings.rating_weight }};
    letter-spacing: {{ block.settings.rating_spacing }}px;
    line-height: {{ block.settings.rating_line_height }};
    margin-bottom: 12px;
  }

  .dp-feature__stars-{{ ai_gen_id }} {
    letter-spacing: {{ block.settings.star_spacing }}px;
    color: {{ block.settings.star_color }};
  }

  .dp-feature__trust-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.trust_size }}px;
    font-weight: {{ block.settings.trust_weight }};
    letter-spacing: {{ block.settings.trust_spacing }}px;
    line-height: {{ block.settings.trust_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .dp-feature__edition-label-{{ ai_gen_id }} {
    display: block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    letter-spacing: {{ block.settings.label_spacing }}px;
    text-transform: uppercase;
    margin: 0 0 10px;
    color: {{ block.settings.heading_color }};
  }

  .dp-feature__variants-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 18px;
  }

  .dp-feature__variant-{{ ai_gen_id }} {
    position: relative;
  }

  .dp-feature__variant-{{ ai_gen_id }} input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .dp-feature__variant-box-{{ ai_gen_id }} {
    min-height: {{ block.settings.variant_height }}px;
    border: 1px solid {{ block.settings.variant_border }};
    border-radius: {{ block.settings.variant_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 8px 10px;
    background: #ffffff;
    cursor: pointer;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.variant_text_size }}px;
    font-weight: {{ block.settings.variant_text_weight }};
    letter-spacing: {{ block.settings.variant_text_spacing }}px;
    line-height: {{ block.settings.variant_text_line_height }};
    text-align: center;
    text-transform: uppercase;
    transition: border-color .2s ease, color .2s ease, background .2s ease;
  }

  .dp-feature__variant-box-{{ ai_gen_id }} img {
    width: 44px;
    height: 24px;
    object-fit: contain;
    display: block;
  }

  .dp-feature__variant-{{ ai_gen_id }} input:checked + .dp-feature__variant-box-{{ ai_gen_id }} {
    border-color: {{ block.settings.accent_color }};
    color: {{ block.settings.accent_color }};
    box-shadow: inset 0 0 0 1px {{ block.settings.accent_color }};
  }

  .dp-feature__price-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    letter-spacing: {{ block.settings.price_spacing }}px;
    line-height: {{ block.settings.price_line_height }};
    margin: 0 0 10px;
    color: {{ block.settings.heading_color }};
  }

  .dp-feature__quantity-label-{{ ai_gen_id }} {
    display: block;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.quantity_label_size }}px;
    font-weight: {{ block.settings.quantity_label_weight }};
    letter-spacing: {{ block.settings.quantity_label_spacing }}px;
    line-height: {{ block.settings.quantity_label_line_height }};
    margin-bottom: 6px;
  }

  .dp-feature__buy-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: stretch;
    margin-bottom: 12px;
  }

  .dp-feature__quantity-{{ ai_gen_id }} {
    display: inline-flex;
    border: 1px solid {{ block.settings.input_border }};
    background: #ffffff;
    height: {{ block.settings.button_height }}px;
  }

  .dp-feature__qty-btn-{{ ai_gen_id }} {
    width: 44px;
    border: 0;
    background: #ffffff;
    cursor: pointer;
    font-size: {{ block.settings.qty_button_size }}px;
    font-weight: {{ block.settings.qty_button_weight }};
  }

  .dp-feature__qty-input-{{ ai_gen_id }} {
    width: 48px;
    border: 0;
    border-left: 1px solid {{ block.settings.input_border }};
    border-right: 1px solid {{ block.settings.input_border }};
    text-align: center;
    font-size: {{ block.settings.qty_input_size }}px;
    font-weight: {{ block.settings.qty_input_weight }};
    letter-spacing: {{ block.settings.qty_input_spacing }}px;
    -moz-appearance: textfield;
  }

  .dp-feature__qty-input-{{ ai_gen_id }}::-webkit-inner-spin-button,
  .dp-feature__qty-input-{{ ai_gen_id }}::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .dp-feature__add-{{ ai_gen_id }} {
    width: 100%;
    min-height: {{ block.settings.button_height }}px;
    border: 0;
    border-radius: {{ block.settings.button_radius }}px;
    background: {{ block.settings.button_bg }};
    color: {{ block.settings.button_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    letter-spacing: {{ block.settings.button_text_spacing }}px;
    text-transform: uppercase;
    cursor: pointer;
  }

  .dp-feature__add-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg }};
  }

  .dp-feature__add-{{ ai_gen_id }}:disabled {
    opacity: .55;
    cursor: not-allowed;
  }

  .dp-feature__dynamic-{{ ai_gen_id }} {
    margin-bottom: 12px;
  }

  .dp-feature__dynamic-{{ ai_gen_id }} .shopify-payment-button__button {
    min-height: {{ block.settings.dynamic_button_height }}px;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.dynamic_button_text_size }}px;
    font-weight: {{ block.settings.dynamic_button_text_weight }};
    letter-spacing: {{ block.settings.dynamic_button_text_spacing }}px;
  }

  .dp-feature__payment-note-{{ ai_gen_id }} {
    display: block;
    text-align: center;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.payment_note_size }}px;
    font-weight: {{ block.settings.payment_note_weight }};
    letter-spacing: {{ block.settings.payment_note_spacing }}px;
    line-height: {{ block.settings.payment_note_line_height }};
    color: {{ block.settings.muted_color }};
    text-decoration: underline;
    margin-bottom: 18px;
  }

  .dp-feature__features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid {{ block.settings.feature_border }};
  }

  .dp-feature__feature-{{ ai_gen_id }} {
    min-height: {{ block.settings.feature_height }}px;
    border-right: 1px solid {{ block.settings.feature_border }};
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-align: center;
    padding: 8px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: {{ block.settings.feature_text_size }}px;
    font-weight: {{ block.settings.feature_text_weight }};
    letter-spacing: {{ block.settings.feature_text_spacing }}px;
    line-height: {{ block.settings.feature_text_line_height }};
  }

  .dp-feature__feature-{{ ai_gen_id }}:last-child {
    border-right: 0;
  }

  .dp-feature__feature-{{ ai_gen_id }} svg {
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    stroke: currentColor;
  }

  .dp-feature__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    background: #f4f4f4;
  }

  @media screen and (max-width: 749px) {
    .dp-feature-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_outer_padding }}px;
      background: {{ block.settings.mobile_section_bg }};
    }

    .dp-feature__shell-{{ ai_gen_id }} {
      border: {{ block.settings.mobile_border_width }}px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.mobile_border_radius }}px;
      padding: {{ block.settings.mobile_inner_padding }}px;
      overflow: hidden;
    }

    .dp-feature__top-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.mobile_header_gap }}px;
    }

    .dp-feature__kicker-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_kicker_size }}px;
      letter-spacing: {{ block.settings.mobile_kicker_spacing }}px;
      line-height: {{ block.settings.mobile_kicker_line_height }};
    }

    .dp-feature__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
      line-height: {{ block.settings.mobile_heading_line_height }};
      letter-spacing: {{ block.settings.mobile_heading_spacing }}px;
      margin-bottom: 5px;
    }

    .dp-feature__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_subheading_size }}px;
      line-height: {{ block.settings.mobile_subheading_line_height }};
      letter-spacing: {{ block.settings.mobile_subheading_spacing }}px;
    }

    .dp-feature__grid-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .dp-feature__media-{{ ai_gen_id }} {
      border-radius: {{ block.settings.mobile_image_radius }}px;
      margin-bottom: 8px;
      order: 1;
      aspect-ratio: {{ block.settings.mobile_image_aspect }};
      height: auto;
      min-height: 0;
    }

    .dp-feature__image-{{ ai_gen_id }},
    .dp-feature__video-{{ ai_gen_id }},
    .dp-feature__external-video-{{ ai_gen_id }},
    .dp-feature__media-slide-{{ ai_gen_id }} iframe {
      width: 100%;
      height: 100%;
      min-height: 0;
      aspect-ratio: auto;
      object-fit: cover;
    }

    .dp-feature__media-arrow-{{ ai_gen_id }} {
      width: 32px;
      height: 32px;
      font-size: 22px;
    }

    .dp-feature__media-arrow--prev-{{ ai_gen_id }} {
      left: 8px;
    }

    .dp-feature__media-arrow--next-{{ ai_gen_id }} {
      right: 8px;
    }

    .dp-feature__counter-{{ ai_gen_id }} {
      left: 10px;
      bottom: 10px;
      font-size: {{ block.settings.mobile_counter_size }}px;
      letter-spacing: {{ block.settings.mobile_counter_spacing }}px;
      padding: 6px 8px;
    }

    .dp-feature__card-{{ ai_gen_id }} {
      order: 2;
    }

    .dp-feature__product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_product_title_size }}px;
      line-height: {{ block.settings.mobile_product_title_line_height }};
      letter-spacing: {{ block.settings.mobile_product_title_spacing }}px;
      margin-bottom: 6px;
    }

    .dp-feature__rating-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_rating_size }}px;
      letter-spacing: {{ block.settings.mobile_rating_spacing }}px;
      line-height: {{ block.settings.mobile_rating_line_height }};
      margin-bottom: 8px;
    }

    .dp-feature__trust-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_trust_size }}px;
      letter-spacing: {{ block.settings.mobile_trust_spacing }}px;
      line-height: {{ block.settings.mobile_trust_line_height }};
      margin-bottom: 10px;
    }

    .dp-feature__edition-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_label_size }}px;
      letter-spacing: {{ block.settings.mobile_label_spacing }}px;
      margin-bottom: 8px;
    }

    .dp-feature__variants-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 7px;
      margin-bottom: 12px;
    }

    .dp-feature__variant-box-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_variant_height }}px;
      font-size: {{ block.settings.mobile_variant_text_size }}px;
      letter-spacing: {{ block.settings.mobile_variant_text_spacing }}px;
      line-height: {{ block.settings.mobile_variant_text_line_height }};
      padding: 6px 5px;
      gap: 6px;
    }

    .dp-feature__variant-box-{{ ai_gen_id }} img {
      width: 34px;
      height: 18px;
    }

    .dp-feature__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_price_size }}px;
      letter-spacing: {{ block.settings.mobile_price_spacing }}px;
      line-height: {{ block.settings.mobile_price_line_height }};
      margin-bottom: 8px;
    }

    .dp-feature__quantity-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_quantity_label_size }}px;
      letter-spacing: {{ block.settings.mobile_quantity_label_spacing }}px;
      line-height: {{ block.settings.mobile_quantity_label_line_height }};
      margin-bottom: 5px;
    }

    .dp-feature__buy-row-{{ ai_gen_id }} {
      grid-template-columns: auto 1fr;
      gap: 10px;
      margin-bottom: 8px;
    }

    .dp-feature__quantity-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_button_height }}px;
    }

    .dp-feature__qty-btn-{{ ai_gen_id }} {
      width: 34px;
      font-size: {{ block.settings.mobile_qty_button_size }}px;
    }

    .dp-feature__qty-input-{{ ai_gen_id }} {
      width: 38px;
      font-size: {{ block.settings.mobile_qty_input_size }}px;
      letter-spacing: {{ block.settings.mobile_qty_input_spacing }}px;
    }

    .dp-feature__add-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_button_height }}px;
      font-size: {{ block.settings.mobile_button_text_size }}px;
      letter-spacing: {{ block.settings.mobile_button_text_spacing }}px;
    }

    .dp-feature__dynamic-{{ ai_gen_id }} {
      margin-bottom: 8px;
    }

    .dp-feature__dynamic-{{ ai_gen_id }} .shopify-payment-button__button {
      min-height: {{ block.settings.mobile_dynamic_button_height }}px;
      font-size: {{ block.settings.mobile_dynamic_button_text_size }}px;
      letter-spacing: {{ block.settings.mobile_dynamic_button_text_spacing }}px;
      border-radius: {{ block.settings.button_radius }}px;
    }

    .dp-feature__payment-note-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_payment_note_size }}px;
      letter-spacing: {{ block.settings.mobile_payment_note_spacing }}px;
      line-height: {{ block.settings.mobile_payment_note_line_height }};
      margin-bottom: 12px;
    }

    .dp-feature__features-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
    }

    .dp-feature__feature-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_feature_height }}px;
      font-size: {{ block.settings.mobile_feature_text_size }}px;
      letter-spacing: {{ block.settings.mobile_feature_text_spacing }}px;
      line-height: {{ block.settings.mobile_feature_text_line_height }};
      padding: 6px 2px;
    }

    .dp-feature__feature-{{ ai_gen_id }} svg {
      width: {{ block.settings.mobile_feature_icon_size }}px;
      height: {{ block.settings.mobile_feature_icon_size }}px;
    }
  }
{% endstyle %}

<dp-feature-{{ ai_gen_id }} class="dp-feature-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product != blank %}
    {% assign current_variant = product.selected_or_first_available_variant %}
    {% assign video_media = product.media | where: 'media_type', 'video' %}
    {% assign external_video_media = product.media | where: 'media_type', 'external_video' %}
    {% assign image_media = product.media | where: 'media_type', 'image' %}
    {% assign media_count = video_media.size | plus: external_video_media.size | plus: image_media.size %}

    <div class="dp-feature__shell-{{ ai_gen_id }}">
      <div class="dp-feature__top-{{ ai_gen_id }}">
        {% if block.settings.kicker != blank %}
          <p class="dp-feature__kicker-{{ ai_gen_id }}">{{ block.settings.kicker }}</p>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="dp-feature__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.subheading != blank %}
          <p class="dp-feature__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>

      <div class="dp-feature__grid-{{ ai_gen_id }}">
        <div class="dp-feature__media-{{ ai_gen_id }}" data-product-media-slider>
          <div class="dp-feature__media-track-{{ ai_gen_id }}" data-product-media-track>
            {% assign video_class = 'dp-feature__video-' | append: ai_gen_id %}
            {% assign external_video_class = 'dp-feature__external-video-' | append: ai_gen_id %}

            {% for media in video_media %}
              <div class="dp-feature__media-slide-{{ ai_gen_id }}" data-media-slide data-media-id="{{ media.id }}">
                {{ media | video_tag: controls: false, muted: true, autoplay: true, loop: true, playsinline: true, preload: 'auto', class: video_class }}
              </div>
            {% endfor %}

            {% for media in external_video_media %}
              <div class="dp-feature__media-slide-{{ ai_gen_id }}" data-media-slide data-media-id="{{ media.id }}">
                {{ media | external_video_tag: class: external_video_class }}
              </div>
            {% endfor %}

            {% for media in image_media %}
              <div class="dp-feature__media-slide-{{ ai_gen_id }}" data-media-slide data-media-id="{{ media.id }}">
                <img
                  src="{{ media.preview_image | image_url: width: 1600 }}"
                  alt="{{ media.alt | escape }}"
                  class="dp-feature__image-{{ ai_gen_id }}"
                  loading="{% if forloop.first and video_media.size == 0 and external_video_media.size == 0 %}eager{% else %}lazy{% endif %}"
                  width="{{ media.preview_image.width }}"
                  height="{{ media.preview_image.height }}"
                >
              </div>
            {% endfor %}

            {% if media_count == 0 and product.featured_image %}
              {% assign media_count = 1 %}
              <div class="dp-feature__media-slide-{{ ai_gen_id }}" data-media-slide data-media-id="{{ product.featured_media.id }}">
                <img
                  src="{{ product.featured_image | image_url: width: 1600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="dp-feature__image-{{ ai_gen_id }}"
                  loading="eager"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              </div>
            {% endif %}
          </div>

          {% if media_count > 1 %}
            <button class="dp-feature__media-arrow-{{ ai_gen_id }} dp-feature__media-arrow--prev-{{ ai_gen_id }}" type="button" data-media-prev aria-label="Previous media">‹</button>
            <button class="dp-feature__media-arrow-{{ ai_gen_id }} dp-feature__media-arrow--next-{{ ai_gen_id }}" type="button" data-media-next aria-label="Next media">›</button>
          {% endif %}

          <span class="dp-feature__counter-{{ ai_gen_id }}" data-media-counter>1/{{ media_count }}</span>
        </div>

        <div class="dp-feature__card-{{ ai_gen_id }}">
          <h3 class="dp-feature__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

          {% if block.settings.show_rating %}
            <div class="dp-feature__rating-{{ ai_gen_id }}">
              <span class="dp-feature__stars-{{ ai_gen_id }}">★★★★½</span>
              <span>({{ block.settings.review_count }} reviews)</span>
            </div>
          {% endif %}

          {% if block.settings.trust_text != blank %}
            <p class="dp-feature__trust-{{ ai_gen_id }}">{{ block.settings.trust_text }}</p>
          {% endif %}

          {% form 'product', product %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

            {% if product.variants.size > 1 %}
              <span class="dp-feature__edition-label-{{ ai_gen_id }}">{{ block.settings.edition_label }}</span>

              <div class="dp-feature__variants-{{ ai_gen_id }}">
                {% for variant in product.variants limit: 4 %}
                  <label class="dp-feature__variant-{{ ai_gen_id }}">
                    <input
                      type="radio"
                      name="edition-option-{{ ai_gen_id }}"
                      value="{{ variant.id }}"
                      data-variant-radio
                      data-price-html="{{ variant.price | money | escape }}"
                      data-available="{{ variant.available }}"
                      data-url="{{ product.url }}?variant={{ variant.id }}"
                      data-featured-media-id="{% if variant.featured_media %}{{ variant.featured_media.id }}{% elsif variant.image %}{{ variant.image.id }}{% endif %}"
                      {% if variant.id == current_variant.id %}checked{% endif %}
                    >

                    {% liquid
                      assign variant_icon = blank
                      case forloop.index
                        when 1
                          assign variant_icon = block.settings.variant_1_icon
                        when 2
                          assign variant_icon = block.settings.variant_2_icon
                        when 3
                          assign variant_icon = block.settings.variant_3_icon
                        when 4
                          assign variant_icon = block.settings.variant_4_icon
                      endcase
                    %}

                    <span class="dp-feature__variant-box-{{ ai_gen_id }}">
                      {% if variant_icon != blank %}
                        <img src="{{ variant_icon | image_url: width: 120 }}" alt="{{ variant.title | escape }}" loading="lazy" width="120" height="60">
                      {% endif %}
                      <span>{{ variant.title }}</span>
                    </span>
                  </label>
                {% endfor %}
              </div>
            {% endif %}

            <p class="dp-feature__price-{{ ai_gen_id }}" data-product-price>
              {{ current_variant.price | money }}
            </p>

            <label class="dp-feature__quantity-label-{{ ai_gen_id }}" for="Quantity-{{ ai_gen_id }}">
              {{ block.settings.quantity_label }}
            </label>

            <div class="dp-feature__buy-row-{{ ai_gen_id }}">
              <div class="dp-feature__quantity-{{ ai_gen_id }}">
                <button type="button" class="dp-feature__qty-btn-{{ ai_gen_id }}" data-qty-minus aria-label="Decrease quantity">−</button>
                <input id="Quantity-{{ ai_gen_id }}" class="dp-feature__qty-input-{{ ai_gen_id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" class="dp-feature__qty-btn-{{ ai_gen_id }}" data-qty-plus aria-label="Increase quantity">+</button>
              </div>

              <button type="submit" name="add" class="dp-feature__add-{{ ai_gen_id }}" data-add-button {% unless current_variant.available %}disabled{% endunless %}>
                {% if current_variant.available %}
                  {{ block.settings.button_text }}
                {% else %}
                  Sold out
                {% endif %}
              </button>
            </div>

            {% if block.settings.show_dynamic_checkout %}
              <div class="dp-feature__dynamic-{{ ai_gen_id }}">
                {{ form | payment_button }}
              </div>
            {% endif %}
          {% endform %}

          {% if block.settings.payment_note != blank %}
            <span class="dp-feature__payment-note-{{ ai_gen_id }}">{{ block.settings.payment_note }}</span>
          {% endif %}

          {% if block.settings.show_features %}
            <div class="dp-feature__features-{{ ai_gen_id }}">
              <div class="dp-feature__feature-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none"><path d="M4 12l2-5h10l4 5v5h-2a2 2 0 0 1-4 0H10a2 2 0 0 1-4 0H4v-5Z" stroke-width="1.8"/><path d="M7 12h10" stroke-width="1.8"/></svg>
                <span>{{ block.settings.feature_1 }}</span>
              </div>

              <div class="dp-feature__feature-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 3v3M12 18v3M3 12h3M18 12h3" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke-width="1.8"/></svg>
                <span>{{ block.settings.feature_2 }}</span>
              </div>

              <div class="dp-feature__feature-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none"><path d="M5 12a7 7 0 0 1 14 0v4a3 3 0 0 1-3 3h-1" stroke-width="1.8"/><path d="M5 12v4h3v-5H5Zm14 0v4h-3v-5h3Z" stroke-width="1.8"/></svg>
                <span>{{ block.settings.feature_3 }}</span>
              </div>

              <div class="dp-feature__feature-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3Z" stroke-width="1.8"/><path d="M9 12l2 2 4-5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>{{ block.settings.feature_4 }}</span>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="dp-feature__empty-{{ ai_gen_id }}">Select a product.</div>
  {% endif %}
</dp-feature-{{ ai_gen_id }}>

<script>
  (function() {
    class DPFeature{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        const qtyInput = this.querySelector('input[name="quantity"]');
        const minus = this.querySelector('[data-qty-minus]');
        const plus = this.querySelector('[data-qty-plus]');
        const variantInput = this.querySelector('[data-variant-id-input]');
        const price = this.querySelector('[data-product-price]');
        const addButton = this.querySelector('[data-add-button]');
        const radios = this.querySelectorAll('[data-variant-radio]');

        const mediaTrack = this.querySelector('[data-product-media-track]');
        const mediaSlides = this.querySelectorAll('[data-media-slide]');
        const mediaPrev = this.querySelector('[data-media-prev]');
        const mediaNext = this.querySelector('[data-media-next]');
        const mediaCounter = this.querySelector('[data-media-counter]');

        if (minus && qtyInput) {
          minus.addEventListener('click', function() {
            const current = parseInt(qtyInput.value || '1', 10);
            qtyInput.value = Math.max(1, current - 1);
          });
        }

        if (plus && qtyInput) {
          plus.addEventListener('click', function() {
            const current = parseInt(qtyInput.value || '1', 10);
            qtyInput.value = current + 1;
          });
        }

        function updateMediaCounter() {
          if (!mediaTrack || !mediaCounter || !mediaSlides.length) return;

          const slideWidth = mediaSlides[0].offsetWidth || mediaTrack.clientWidth;
          const rawIndex = Math.round(mediaTrack.scrollLeft / slideWidth);
          const index = Math.max(0, Math.min(mediaSlides.length - 1, rawIndex));

          mediaCounter.textContent = (index + 1) + '/' + mediaSlides.length;
        }

        function goToMedia(index) {
          if (!mediaTrack || !mediaSlides.length) return;

          const safeIndex = Math.max(0, Math.min(mediaSlides.length - 1, index));
          const slideWidth = mediaSlides[0].offsetWidth || mediaTrack.clientWidth;

          mediaTrack.scrollTo({
            left: slideWidth * safeIndex,
            behavior: 'smooth'
          });

          window.requestAnimationFrame(updateMediaCounter);
        }

        function scrollMedia(direction) {
          if (!mediaTrack || !mediaSlides.length) return;

          const slideWidth = mediaSlides[0].offsetWidth || mediaTrack.clientWidth;
          const currentIndex = Math.round(mediaTrack.scrollLeft / slideWidth);

          goToMedia(currentIndex + direction);
        }

        radios.forEach(function(radio) {
          radio.addEventListener('change', function() {
            if (!radio.checked) return;

            const available = radio.dataset.available === 'true';

            if (variantInput) {
              variantInput.value = radio.value;
            }

            if (price) {
              price.innerHTML = radio.dataset.priceHtml || '';
            }

            if (addButton) {
              addButton.disabled = !available;
              addButton.textContent = available ? '{{ block.settings.button_text | escape }}' : 'Sold out';
            }

            const featuredMediaId = radio.dataset.featuredMediaId;

            if (featuredMediaId && mediaSlides.length) {
              const targetIndex = Array.from(mediaSlides).findIndex(function(slide) {
                return slide.dataset.mediaId === featuredMediaId;
              });

              if (targetIndex > -1) {
                goToMedia(targetIndex);
              }
            }

            if (radio.dataset.url) {
              window.history.replaceState({}, '', radio.dataset.url);
            }
          });
        });

        const urlVariantId = new URLSearchParams(window.location.search).get('variant');

        if (urlVariantId) {
          const matchingRadio = Array.from(radios).find(function(radio) {
            return radio.value === urlVariantId;
          });

          if (matchingRadio) {
            matchingRadio.checked = true;
            matchingRadio.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }

        if (mediaPrev) mediaPrev.addEventListener('click', function() { scrollMedia(-1); });
        if (mediaNext) mediaNext.addEventListener('click', function() { scrollMedia(1); });

        if (mediaTrack) {
          mediaTrack.addEventListener('scroll', function() {
            window.requestAnimationFrame(updateMediaCounter);
          });
          window.addEventListener('resize', updateMediaCounter);
          updateMediaCounter();
        }
      }
    }

    if (!customElements.get('dp-feature-{{ ai_gen_id }}')) {
      customElements.define('dp-feature-{{ ai_gen_id }}', DPFeature{{ ai_gen_id }});
    }
  })();
</script>

