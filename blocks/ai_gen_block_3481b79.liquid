{% doc %}
  @prompt
    need product media 1st image on center full and on left bertically other images 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-media-gallery-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-media-thumbnails-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.thumbnail_gap }}px;
    width: {{ block.settings.thumbnail_width }}px;
    flex-shrink: 0;
  }

  .ai-product-media-thumbnail-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    cursor: pointer;
    border: {{ block.settings.thumbnail_border_width }}px solid {{ block.settings.thumbnail_border_color }};
    border-radius: {{ block.settings.thumbnail_border_radius }}px;
    overflow: hidden;
    transition: all 0.3s ease;
    opacity: {{ block.settings.thumbnail_opacity | divided_by: 100.0 }};
  }

  .ai-product-media-thumbnail-{{ ai_gen_id }}:hover {
    opacity: 1;
    border-color: {{ block.settings.thumbnail_hover_border_color }};
  }

  .ai-product-media-thumbnail-{{ ai_gen_id }}.active {
    opacity: 1;
    border-color: {{ block.settings.thumbnail_active_border_color }};
  }

  .ai-product-media-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-media-main-{{ ai_gen_id }} {
    flex-grow: 1;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.main_border_radius }}px;
  }

  .ai-product-media-main-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-product-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.main_border_radius }}px;
  }

  .ai-product-media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-media-gallery-{{ ai_gen_id }} {
      flex-direction: column-reverse;
      width: 100%;
    }

    .ai-product-media-thumbnails-{{ ai_gen_id }} {
      flex-direction: row;
      width: 100%;
      overflow-x: auto;
    }

    .ai-product-media-thumbnail-{{ ai_gen_id }} {
      min-width: {{ block.settings.thumbnail_width | times: 0.7 }}px;
    }
  }
{% endstyle %}

<product-media-gallery-{{ ai_gen_id }}
  class="ai-product-media-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if product.media.size > 0 %}
    <div class="ai-product-media-thumbnails-{{ ai_gen_id }}">
      {% for media in product.media limit: block.settings.max_thumbnails %}
        <div
          class="ai-product-media-thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-media-index="{{ forloop.index0 }}"
        >
          {% if media.media_type == 'image' %}
            <img
              src="{{ media | image_url: width: 200 }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% elsif media.media_type == 'video' or media.media_type == 'external_video' %}
            <img
              src="{{ media.preview_image | image_url: width: 200 }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% elsif media.media_type == 'model' %}
            <img
              src="{{ media.preview_image | image_url: width: 200 }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-product-media-main-{{ ai_gen_id }}">
      {% assign first_media = product.media.first %}
      {% if first_media.media_type == 'image' %}
        <img
          class="ai-product-media-main-image-{{ ai_gen_id }}"
          src="{{ first_media | image_url: width: 1200 }}"
          alt="{{ first_media.alt | escape }}"
          width="{{ first_media.width }}"
          height="{{ first_media.height }}"
        >
      {% elsif first_media.media_type == 'video' %}
        {% assign video_class = 'ai-product-media-main-image-' | append: ai_gen_id %}
        {{ first_media | video_tag: controls: true, class: video_class }}
      {% elsif first_media.media_type == 'external_video' %}
        {% assign video_class = 'ai-product-media-main-image-' | append: ai_gen_id %}
        {{ first_media | external_video_tag: class: video_class }}
      {% elsif first_media.media_type == 'model' %}
        {% assign model_class = 'ai-product-media-main-image-' | append: ai_gen_id %}
        {{ first_media | model_viewer_tag: class: model_class }}
      {% endif %}
    </div>
  {% else %}
    <div class="ai-product-media-thumbnails-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        <div class="ai-product-media-thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}">
          <div class="ai-product-media-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="ai-product-media-main-{{ ai_gen_id }}">
      <div class="ai-product-media-placeholder-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    </div>
  {% endif %}
</product-media-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductMediaGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.thumbnails = this.querySelectorAll('.ai-product-media-thumbnail-{{ ai_gen_id }}');
        this.mainContainer = this.querySelector('.ai-product-media-main-{{ ai_gen_id }}');
        this.productMedia = {{ product.media | json }};
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.thumbnails.forEach((thumbnail, index) => {
          thumbnail.addEventListener('click', () => {
            this.switchMedia(index);
          });
        });
      }

      switchMedia(index) {
        this.thumbnails.forEach(thumb => thumb.classList.remove('active'));
        this.thumbnails[index].classList.add('active');

        const media = this.productMedia[index];
        if (!media) return;

        let mediaHTML = '';
        
        if (media.media_type === 'image') {
          mediaHTML = `<img
            class="ai-product-media-main-image-{{ ai_gen_id }}"
            src="${media.src.replace(/\.(jpg|jpeg|png|gif|webp)/, '_1200x.$1')}"
            alt="${media.alt || ''}"
            width="${media.width}"
            height="${media.height}"
          >`;
        } else if (media.media_type === 'video') {
          mediaHTML = `<video
            class="ai-product-media-main-image-{{ ai_gen_id }}"
            controls
            src="${media.sources[0].url}"
          ></video>`;
        } else if (media.media_type === 'external_video') {
          const videoId = media.external_id;
          if (media.host === 'youtube') {
            mediaHTML = `<iframe
              class="ai-product-media-main-image-{{ ai_gen_id }}"
              src="https://www.youtube.com/embed/${videoId}"
              frameborder="0"
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              style="width: 100%; aspect-ratio: 16/9;"
            ></iframe>`;
          } else if (media.host === 'vimeo') {
            mediaHTML = `<iframe
              class="ai-product-media-main-image-{{ ai_gen_id }}"
              src="https://player.vimeo.com/video/${videoId}"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              style="width: 100%; aspect-ratio: 16/9;"
            ></iframe>`;
          }
        } else if (media.media_type === 'model') {
          mediaHTML = `<model-viewer
            class="ai-product-media-main-image-{{ ai_gen_id }}"
            src="${media.sources[0].url}"
            alt="${media.alt || ''}"
            camera-controls
            auto-rotate
            style="width: 100%; height: 600px;"
          ></model-viewer>`;
        }

        this.mainContainer.innerHTML = mediaHTML;
      }
    }

    customElements.define('product-media-gallery-{{ ai_gen_id }}', ProductMediaGallery{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product media gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between thumbnails and main",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Thumbnails"
    },
    {
      "type": "range",
      "id": "thumbnail_width",
      "label": "Thumbnail width",
      "min": 50,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "thumbnail_gap",
      "label": "Gap between thumbnails",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "max_thumbnails",
      "label": "Maximum thumbnails",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "thumbnail_opacity",
      "label": "Thumbnail opacity",
      "min": 30,
      "max": 100,
      "step": 10,
      "unit": "%",
      "default": 60
    },
    {
      "type": "range",
      "id": "thumbnail_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "thumbnail_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "thumbnail_border_color",
      "label": "Border color",
      "default": "#d3cec5"
    },
    {
      "type": "color",
      "id": "thumbnail_hover_border_color",
      "label": "Hover border color",
      "default": "#030302"
    },
    {
      "type": "color",
      "id": "thumbnail_active_border_color",
      "label": "Active border color",
      "default": "#030302"
    },
    {
      "type": "header",
      "content": "Main image"
    },
    {
      "type": "range",
      "id": "main_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Product media gallery"
    }
  ]
}
{% endschema %}
